{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin-top": 0,
  "margin-bottom": 0,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 4,
  "exclusive": true,
  "gtk-layer-shell": true,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "network", "custom/bluetooth-panel", "tray", "custom/power"],

  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "sort-by": "number",
    "format": "{windows}",
    "format-window-separator": "  ",
    "window-rewrite-default": "{title}",
    "window-rewrite": {
      "class<ghostty>": "",
      "class<Alacritty>": "",
      "class<firefox>": "󰈹",
      "class<brave-browser>": "󰆍",
      "class<code>": "󰨞",
      "class<Cursor>": "󰨞",
      "class<discord>": "󰙯",
      "class<spotify>": "󰓇"
    }
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 48,
    "separate-outputs": true
  },

  "clock": {
    "timezone": "Europe/Amsterdam",
    "format": "{:%H:%M}",
    "format-alt": "{:%a %d %b  %H:%M}"
  },

  "cpu": {
    "interval": 3,
    "format": " {usage}%"
  },

  "memory": {
    "interval": 5,
    "format": " {percentage}%"
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " Muted",
    "scroll-step": 5,
    "on-click": "pavucontrol-qt"
  },

  "network": {
    "interval": 5,
    "format-wifi": " {signalStrength}%",
    "format-ethernet": " Connected",
    "format-disconnected": " Offline",
    "on-click": "nm-connection-editor"
  },

  "custom/bluetooth-panel": {
    "exec": "~/.local/bin/bluetooth-waybar",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "tooltip": true,
    "on-click": "bluetooth-panel",
    "on-click-right": "bluetooth-panel-menu"
  },

  "custom/power": {
    "format": "",
    "tooltip": false,
    "on-click": "~/.config/dotfiles/bin/powermenu"
  },

  "tray": {
    "spacing": 6,
    "icon-size": 14
  }
}
