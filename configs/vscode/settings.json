{
  "diff_view_style": "unified",
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "tree_view": false,
    "dock": "left"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "terminal": {
    "font_family": "monospace"
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never"
  },
  "cursor_blink": true,
  "autosave": "on_focus_change",
  "buffer_font_size": 19.0,
  "buffer_font_fallbacks": [
    "Comic Sans MS",
    "Patrick Hand",
    "Caveat"
  ],
  "buffer_font_family": "Comic Neue",
  "colorize_brackets": true,
  "linked_edits": true,
  "show_whitespaces": "selection",
  "soft_wrap": "editor_width",
  "hard_tabs": false,
  "tab_size": 4,
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "vim_mode": false,
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "icon_theme": "Warm Charmed Icons",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Ayu Dark"
  },
  "window.commandCenter": true,
  "workbench.settings.openDefaultKeybindings": true,
  "editor.fontSize": 19,
  "editor.fontFamily": "Comic Neue, Comic Sans MS, Patrick Hand, Caveat",
  "editor.fontWeight": "bold",
  "editor.letterSpacing": 1.49,
  "editor.lineHeight": 1.5,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxyl.vscode-oxyl",
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsOpacity": 0.05,
  "editor.renderWhitespace": "selection",
  "editor.cursorBlinking": "smooth",
  "files.trimTrailingWhitespace": true,
  "editor.linkedEditing": true,
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.emptyWindow": true,
  "typescript.tsserver.maxTsServerMemory": 4000,
  "git.enableSmartCommit": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "workbench.sideBar.location": "right",
  "workbench.colorTheme": "Ayu Mirage Bordered",
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "Cargo.toml": "Cargo.lock",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "explorer.confirmDelete": false,
  "cursor.agent_layout_browser_beta_setting": true,
  "cursor.composer.cmdPFilePicker2": true,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.enable_git_worktrees_setting": true,
  "cursor.general.enableShadowWorkspace": true,
  "cursor.general.gitGraphIndexing": "enabled",
  "editor.fontLigatures": true,
  "editor.wordWrap": "on",
  "files.autoSave": "onFocusChange",
  "terminal.external.linuxExec": "ghostty",
  "terminal.external.osxExec": "ghostty",
  "update.releaseTrack": "stable",
  "editor.inlineSuggest.edits.showCollapsed": true,
  "cursor.cpp.disabledLanguages": [
    "plaintext"
],
  "git.openRepositoryInParentFolders": "always",
  "terminal.integrated.fontFamily": "monospace",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "update.mode": "silentlyApplyOnQuit",
"claudeCode.preferredLocation": "panel",
"workbench.iconTheme": "charmed-warm",
"editor.minimap.enabled": false,
"git.autofetch": true
}
