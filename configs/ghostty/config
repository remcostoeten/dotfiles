command = /usr/bin/fish

background-opacity = 0.92
background-opacity-cells = true
background-blur = 24

theme = dotfiles-dark
window-decoration = none
gtk-titlebar = false
window-show-tab-bar = never
gtk-toolbar-style = flat
gtk-custom-css = gtk.css
window-padding-x = 14
window-padding-y = 14

# Font & Typography
# font-family = "JetBrains Mono Nerd Font", "Fira Code", monospace
# font-family = "JetBrains Mono Nerd Font", "Fira Code", monospace
font-family = "Iosevka Nerd Font Propo"

font-size = 14.5

# Terminal Options
confirm-close-surface = false

# Window Behavior
window-width = 120
window-height = 40
window-save-state = always
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Key Bindings
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_tab:this
keybind = ctrl+shift+n=new_window
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+==increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size
# Split operations - Ghostty handles direction automatically
keybind = ctrl+enter=toggle_fullscreen
keybind = ctrl+backquote=goto_split:next

keybind = ctrl+d=new_split:right

# Mouse
mouse-hide-while-typing = true
copy-on-select = true
