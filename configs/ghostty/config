selection-background = #2a2e30
selection-foreground = #f2ece4
split-divider-color = #34393b
window-decoration = none
gtk-titlebar = false
gtk-tabs-location = hidden
gtk-toolbar-style = flat
gtk-custom-css = /home/remco/.config/dotfiles/configs/ghostty/gtk.css
window-padding-x = 18
window-padding-y = 16

# Font & Typography
# font-family = "JetBrains Mono Nerd Font", "Fira Code", monospace
# font-family = "JetBrains Mono Nerd Font", "Fira Code", monospace
font-family = Ubuntu Sans Mono Medium

font-size = 15

# Terminal Options
confirm-close-surface = false

# Window Behavior
window-width = 120
window-height = 40
window-save-state = always
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Key Bindings
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+t=new_window
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+n=new_window
keybind = ctrl+equal=increase_font_size
keybind = ctrl+Minus=decrease_font_size
keybind = ctrl+0=reset_font_size
# Split operations - Ghostty handles direction automatically
keybind = ctrl+enter=new_split
keybind = ctrl+backquote=goto_split:next

keybind = ctrl+d=new_split:right

# Mouse
mouse-hide-while-typing = true
copy-on-select = true
