#!/usr/bin/env bash
set -euo pipefail

readonly THEME="${ROFI_LAUNCHER_THEME:-$HOME/.config/rofi/raycast.rasi}"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(dirname "$SCRIPT_DIR")"
readonly DEFAULT_PINNED_FILE="$REPO_ROOT/configs/rofi/pinned-apps"
readonly DEFAULT_CONFIG_FILE="$REPO_ROOT/configs/rofi/launcher.conf"
readonly DEFAULT_BANG_FILE="$REPO_ROOT/configs/rofi/bang-commands.lua"
readonly PINNED_FILE="${ROFI_LAUNCHER_PINNED:-$HOME/.config/rofi/pinned-apps}"
readonly CONFIG_FILE="${ROFI_LAUNCHER_CONFIG:-$HOME/.config/rofi/launcher.conf}"
readonly BANG_FILE="${ROFI_LAUNCHER_BANGS:-$HOME/.config/rofi/bang-commands.lua}"
readonly STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"
readonly RECENT_FILE="$STATE_DIR/rofi-launcher-recent"
readonly MAX_RECENT=5
readonly FILE_SEARCH_LIMIT="${ROFI_LAUNCHER_FILE_LIMIT:-80}"
readonly FILE_SEARCH_TIMEOUT="${ROFI_LAUNCHER_FILE_TIMEOUT:-3s}"
readonly FD_CMD="$(command -v fd || command -v fdfind || true)"
readonly DEFAULT_EDITOR_CMD="${ROFI_LAUNCHER_EDITOR:-${VISUAL:-${EDITOR:-}}}"

declare -A APP_NAME APP_GENERIC APP_ICON APP_EXEC APP_TERMINAL APP_SEEN
declare -A BANG_TYPE BANG_TEMPLATE BANG_DESCRIPTION BANG_TERMINAL
declare -a APP_IDS=()
declare -a BANG_TRIGGERS=()
declare -a CONFIG_TARGETS=(
    "Live pinned apps:~/.config/rofi/pinned-apps"
    "Live bang commands:~/.config/rofi/bang-commands.lua"
    "Live launcher config:~/.config/rofi/launcher.conf"
    "Repo rofi README:$REPO_ROOT/configs/rofi/README.md"
    "Repo pinned apps:$REPO_ROOT/configs/rofi/pinned-apps"
    "Repo bang commands:$REPO_ROOT/configs/rofi/bang-commands.lua"
    "Repo launcher config:$REPO_ROOT/configs/rofi/launcher.conf"
)
declare -a CONFIG_EDITORS=(nvim vim code zed nano)

PINNED_LABEL="Pinned"
RECENT_LABEL="Recent"
ALL_APPS_LABEL="All Apps"
SEARCH_HOME="${ROFI_LAUNCHER_SEARCH_HOME:-$HOME}"
SEARCH_FOLDERS=(
    "Home:$HOME"
    "Dotfiles:$REPO_ROOT"
    "Config:$HOME/.config"
    "Documents:$HOME/Documents"
    "Downloads:$HOME/Downloads"
)

load_launcher_config() {
    local config_file="$CONFIG_FILE"
    [[ -f "$config_file" ]] || config_file="$DEFAULT_CONFIG_FILE"
    [[ -f "$config_file" ]] && source "$config_file"
}

load_bang_commands() {
    local bang_file="$BANG_FILE"
    local line trigger type template description terminal

    [[ -r "$bang_file" ]] || bang_file="$DEFAULT_BANG_FILE"
    [[ -r "$bang_file" ]] || return 0
    command -v lua >/dev/null 2>&1 || return 0

    while IFS=$'\t' read -r trigger type template description terminal; do
        [[ "$trigger" == "!"* && -n "$template" ]] || continue
        BANG_TRIGGERS+=("$trigger")
        BANG_TYPE["$trigger"]="${type:-shell}"
        BANG_TEMPLATE["$trigger"]="$template"
        BANG_DESCRIPTION["$trigger"]="$description"
        BANG_TERMINAL["$trigger"]="$terminal"
    done < <(lua - "$bang_file" <<'LUA' 2>/dev/null || true
local path = arg[1]
local ok, commands = pcall(dofile, path)
if not ok or type(commands) ~= "table" then
  os.exit(0)
end

local function clean(value)
  value = tostring(value or "")
  value = value:gsub("\t", " "):gsub("\r", " "):gsub("\n", " ")
  return value
end

local function emit(entry)
  if type(entry) ~= "table" then
    return
  end

  local trigger = clean(entry.bang or entry.trigger or entry[1])
  local kind = clean(entry.type or "shell")
  local template = clean(entry.template or entry.command or entry.url or entry[2])
  local description = clean(entry.description or entry.desc or "")
  local terminal = entry.terminal and "true" or "false"

  if trigger:match("^!") and template ~= "" then
    print(table.concat({ trigger, kind, template, description, terminal }, "\t"))
  end
end

for _, entry in ipairs(commands) do
  emit(entry)
end

for trigger, entry in pairs(commands) do
  if type(trigger) == "string" and trigger:match("^!") and type(entry) == "table" then
    entry.bang = entry.bang or trigger
    emit(entry)
  end
end
LUA
    )
}

strip_field_codes() {
    local value="$1"
    value="${value//%f/}"
    value="${value//%F/}"
    value="${value//%u/}"
    value="${value//%U/}"
    value="${value//%i/}"
    value="${value//%c/}"
    value="${value//%k/}"
    printf '%s\n' "$value" | xargs
}

desktop_id_for_path() {
    local path="$1"
    local data_dir

    if [[ "$path" == "$HOME/.local/share/applications/"* ]]; then
        local rel="${path#"$HOME/.local/share/applications/"}"
        printf '%s\n' "${rel//\//-}"
        return 0
    fi

    IFS=: read -r -a data_dirs <<< "${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
    for data_dir in "${data_dirs[@]}"; do
        if [[ "$path" == "$data_dir/applications/"* ]]; then
            local rel="${path#"$data_dir/applications/"}"
            printf '%s\n' "${rel//\//-}"
            return 0
        fi
    done

    basename "$path"
}

load_desktop_file() {
    local path="$1"
    local id name generic icon exec terminal type nodisplay hidden

    id="$(desktop_id_for_path "$path")"
    [[ -n "${APP_SEEN[$id]:-}" ]] && return 0

    type="$(awk -F= '$1 == "Type" {print $2; exit}' "$path")"
    nodisplay="$(awk -F= '$1 == "NoDisplay" {print tolower($2); exit}' "$path")"
    hidden="$(awk -F= '$1 == "Hidden" {print tolower($2); exit}' "$path")"
    [[ "$type" == "Application" || -z "$type" ]] || return 0
    [[ "$nodisplay" != "true" && "$hidden" != "true" ]] || return 0

    name="$(awk -F= '$1 == "Name" {print substr($0, index($0, "=") + 1); exit}' "$path")"
    exec="$(awk -F= '$1 == "Exec" {print substr($0, index($0, "=") + 1); exit}' "$path")"
    [[ -n "$name" && -n "$exec" ]] || return 0

    generic="$(awk -F= '$1 == "GenericName" {print substr($0, index($0, "=") + 1); exit}' "$path")"
    icon="$(awk -F= '$1 == "Icon" {print substr($0, index($0, "=") + 1); exit}' "$path")"
    terminal="$(awk -F= '$1 == "Terminal" {print tolower($2); exit}' "$path")"

    APP_SEEN["$id"]=1
    APP_NAME["$id"]="$name"
    APP_GENERIC["$id"]="$generic"
    APP_ICON["$id"]="$icon"
    APP_EXEC["$id"]="$(strip_field_codes "$exec")"
    APP_TERMINAL["$id"]="$terminal"
    APP_IDS+=("$id")
}

load_apps() {
    local app_dir path
    local -a app_dirs=("$HOME/.local/share/applications")

    IFS=: read -r -a data_dirs <<< "${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
    for app_dir in "${data_dirs[@]}"; do
        app_dirs+=("$app_dir/applications")
    done

    for app_dir in "${app_dirs[@]}"; do
        [[ -d "$app_dir" ]] || continue
        while IFS= read -r -d '' path; do
            load_desktop_file "$path"
        done < <(find "$app_dir" -type f -name '*.desktop' -print0 2>/dev/null)
    done
}

find_app_id() {
    local wanted="$1"
    local id exec_base

    [[ -n "${APP_NAME[$wanted]:-}" ]] && {
        printf '%s\n' "$wanted"
        return 0
    }

    for id in "${APP_IDS[@]}"; do
        exec_base="$(basename "${APP_EXEC[$id]%% *}")"
        if [[ "$wanted" == "$id" || "$wanted" == "$exec_base" || "$wanted.desktop" == "$id" ]]; then
            printf '%s\n' "$id"
            return 0
        fi
    done

    return 1
}

print_separator() {
    local label="$1"

    printf '%s\0nonselectable\x1ftrue\x1factive\x1ftrue\x1fmeta\x1f%s\n' "$label" "$label"
}

print_header() {
    local prompt="$1"
    local message="${2:-}"

    printf '\0prompt\x1f%s\n' "$prompt"
    [[ -n "$message" ]] && printf '\0message\x1f%s\n' "$message"
}

user_path() {
    local path="$1"

    if [[ "$path" == "$HOME"* ]]; then
        printf '~%s\n' "${path#"$HOME"}"
    else
        printf '%s\n' "$path"
    fi
}

url_encode() {
    local value="$1"
    local encoded=""
    local i char hex

    for ((i = 0; i < ${#value}; i++)); do
        char="${value:i:1}"
        case "$char" in
            [a-zA-Z0-9.~_-])
                encoded+="$char"
                ;;
            ' ')
                encoded+="+"
                ;;
            *)
                printf -v hex '%%%02X' "'$char"
                encoded+="$hex"
                ;;
        esac
    done

    printf '%s\n' "$encoded"
}

shell_quote() {
    printf '%q' "$1"
}

print_action() {
    local label="$1"
    local info="$2"
    local icon="${3:-system-search}"
    local meta="${4:-$label}"

    printf '%s\0info\x1f%s\x1ficon\x1f%s\x1fmeta\x1f%s\n' "$label" "$info" "$icon" "$meta"
}

print_notice() {
    local label="$1"
    local icon="${2:-dialog-information}"

    printf '%s\0nonselectable\x1ftrue\x1factive\x1ftrue\x1ficon\x1f%s\x1fmeta\x1f%s\n' "$label" "$icon" "$label"
}

print_app() {
    local id="$1"
    local section="$2"
    local sub="${APP_GENERIC[$id]:-$id}"
    local icon="${APP_ICON[$id]:-application-x-executable}"

    printf '%s\0info\x1f%s\x1ficon\x1f%s\x1fmeta\x1f%s %s %s\n' \
        "${APP_NAME[$id]}" \
        "$id" \
        "$icon" \
        "$section" \
        "$sub" \
        "$id"
}

print_rows() {
    local id wanted
    local -A printed=()
    local -a pinned=() recent=()

    local pinned_file="$PINNED_FILE"
    [[ -f "$pinned_file" ]] || pinned_file="$DEFAULT_PINNED_FILE"

    if [[ -f "$pinned_file" ]]; then
        while IFS= read -r wanted; do
            wanted="${wanted%%#*}"
            wanted="$(printf '%s\n' "$wanted" | xargs)"
            [[ -n "$wanted" ]] || continue
            if id="$(find_app_id "$wanted")"; then
                pinned+=("$id")
            fi
            ((${#pinned[@]} >= 3)) && break
        done < "$pinned_file"
    fi

    print_header "" "Apps filter live. Prefixes run after Enter: !bang args, : commands, :config, / folders, *.md files, **text contents."
    print_action "Settings" "menu:config" "emblem-system" "Open launcher config files"

    if ((${#pinned[@]})); then
        print_separator "$PINNED_LABEL"
        for id in "${pinned[@]}"; do
            print_app "$id" "pinned"
            printed["$id"]=1
        done
    fi

    if [[ -f "$RECENT_FILE" ]]; then
        while IFS= read -r wanted; do
            [[ -n "$wanted" ]] || continue
            if id="$(find_app_id "$wanted")"; then
                [[ -n "${printed[$id]:-}" ]] && continue
                recent+=("$id")
                printed["$id"]=1
            fi
            ((${#recent[@]} >= MAX_RECENT)) && break
        done < "$RECENT_FILE"
    fi

    if ((${#recent[@]})); then
        print_separator "$RECENT_LABEL"
        for id in "${recent[@]}"; do
            print_app "$id" "recent"
        done
    fi

    print_separator "$ALL_APPS_LABEL"
    for id in "${APP_IDS[@]}"; do
        [[ -n "${printed[$id]:-}" ]] && continue
        print_app "$id" "app"
    done
}

print_command_menu() {
    print_header "" "These actions run after Enter. Searches show up to $FILE_SEARCH_LIMIT results and stop after $FILE_SEARCH_TIMEOUT."
    print_action "Pinned apps: edit top 3" "config:pinned" "accessories-text-editor" "configure pinned apps top three"
    print_action "Bang commands: edit ! shortcuts" "config:bangs" "accessories-text-editor" "configure bang commands shortcuts"
    print_action "Config: open rofi configs" "menu:config" "folder" "open rofi config files"
    print_action "/  Folder scopes" "menu:folders" "folder" "/ folders scoped search"
    print_action "*.md  Press Enter to find Markdown files in Home" "search:glob:$SEARCH_HOME:*.md" "text-x-markdown" "markdown files enter search"
    print_action "*.json  Press Enter to find JSON files in Home" "search:glob:$SEARCH_HOME:*.json" "application-json" "json files enter search"
    print_action "**todo  Type **text, then Enter for content search" "hint:**todo" "edit-find" "content search ripgrep enter"

    if ((${#BANG_TRIGGERS[@]})); then
        print_separator "Bang Commands"
        local trigger description
        for trigger in "${BANG_TRIGGERS[@]}"; do
            description="${BANG_DESCRIPTION[$trigger]:-Custom command}"
            print_action "$trigger  $description" "hint:$trigger " "utilities-terminal" "$trigger bang command shortcut"
        done
    fi
}

print_config_menu() {
    local item label path

    print_header "" "Type :config to choose a config, or :config nvim to open the files in an editor."
    print_action "Open config menu in the launcher" "menu:config" "folder" "rofi config shortcuts"
    print_separator "Config Files"
    for item in "${CONFIG_TARGETS[@]}"; do
        label="${item%%:*}"
        path="${item#*:}"
        print_action "$label" "config:file:$path" "text-x-generic" "$path"
    done

    print_separator "Editors"
    for item in "${CONFIG_EDITORS[@]}"; do
        print_action "$item" "config:editor:$item" "utilities-terminal" "open config in $item"
    done
}

print_folder_menu() {
    local item label path

    print_header "" "Select a scope to copy its path hint, or type /path query and press Enter."
    for item in "${SEARCH_FOLDERS[@]}"; do
        label="${item%%:*}"
        path="${item#*:}"
        [[ -d "$path" ]] || continue
        print_action "$label" "hint:$path" "folder" "$path folder scope"
    done
}

print_file_result() {
    local path="$1"
    local root="$2"
    local display="${path#"$root"/}"
    local icon="text-x-generic"

    [[ "$display" == "$path" ]] && display="$path"
    [[ -d "$path" ]] && icon="folder"
    printf '%s\0info\x1ffile:%s\x1ficon\x1f%s\x1fmeta\x1f%s\n' "$display" "$path" "$icon" "$path"
}

print_search_summary() {
    local type="$1"
    local query="$2"
    local root="$3"
    local count="$4"

    print_header "" "$type complete for '$query' in $(user_path "$root"). Showing $count of max $FILE_SEARCH_LIMIT; search stops after $FILE_SEARCH_TIMEOUT."
}

search_file_names() {
    local root="$1"
    local pattern="$2"
    local -a results=()
    local path

    [[ -d "$root" ]] || {
        print_header "" "Folder does not exist: $root"
        print_notice "No search ran. Check the folder path and press Enter again." "dialog-warning"
        return 0
    }

    if [[ -n "$FD_CMD" ]]; then
        mapfile -t results < <(timeout "$FILE_SEARCH_TIMEOUT" "$FD_CMD" --hidden --type f --glob \
            --exclude .git --exclude node_modules --exclude vendor --exclude .cache \
            --exclude .cargo --exclude .rustup --exclude .npm --exclude .pnpm-store \
            --exclude .bun --exclude .deno --exclude .agents --exclude .claude --exclude .codex \
            --exclude .gemini --exclude target --exclude dist \
            --exclude build --exclude .next --exclude pc-backup \
            "$pattern" "$root" 2>/dev/null |
            head -n "$FILE_SEARCH_LIMIT" || true)
    else
        mapfile -t results < <(timeout "$FILE_SEARCH_TIMEOUT" find "$root" \
            \( -path '*/.git' -o -path '*/node_modules' -o -path '*/vendor' -o -path '*/.cache' -o -path '*/.cargo' -o -path '*/.rustup' -o -path '*/.npm' -o -path '*/.pnpm-store' -o -path '*/.bun' -o -path '*/.deno' -o -path '*/.agents' -o -path '*/.claude' -o -path '*/.codex' -o -path '*/.gemini' -o -path '*/target' -o -path '*/dist' -o -path '*/build' -o -path '*/.next' -o -path '*/pc-backup' \) -prune \
            -o -type f -iname "$pattern" -print 2>/dev/null |
            head -n "$FILE_SEARCH_LIMIT" || true)
    fi

    print_search_summary "Filename search" "$pattern" "$root" "${#results[@]}"
    if ((${#results[@]} == 0)); then
        print_notice "No matching files. Refine the path or pattern, then press Enter again." "edit-find"
        return 0
    fi

    for path in "${results[@]}"; do
        print_file_result "$path" "$root"
    done
}

search_file_contents() {
    local root="$1"
    local query="$2"
    local -a results=()
    local path

    [[ -d "$root" ]] || {
        print_header "" "Folder does not exist: $root"
        print_notice "No search ran. Check the folder path and press Enter again." "dialog-warning"
        return 0
    }

    if command -v rg >/dev/null 2>&1; then
        mapfile -t results < <(timeout "$FILE_SEARCH_TIMEOUT" rg -l --hidden \
            --glob '!.git' --glob '!node_modules' --glob '!vendor' --glob '!.cache' \
            --glob '!.cargo' --glob '!.rustup' --glob '!.npm' --glob '!.pnpm-store' \
            --glob '!.bun' --glob '!.deno' --glob '!.agents' --glob '!.claude' --glob '!.codex' \
            --glob '!.gemini' --glob '!target' --glob '!dist' \
            --glob '!build' --glob '!.next' --glob '!pc-backup' \
            -- "$query" "$root" 2>/dev/null |
            head -n "$FILE_SEARCH_LIMIT" || true)
    else
        print_header "" "Install ripgrep for content search."
        print_notice "Content search needs rg." "dialog-warning"
        return 0
    fi

    print_search_summary "Content search" "$query" "$root" "${#results[@]}"
    if ((${#results[@]} == 0)); then
        print_notice "No matching file contents. Refine the path or text, then press Enter again." "edit-find"
        return 0
    fi

    for path in "${results[@]}"; do
        print_file_result "$path" "$root"
    done
}

ensure_user_pinned_file() {
    mkdir -p "$(dirname "$PINNED_FILE")"
    if [[ ! -f "$PINNED_FILE" ]]; then
        if [[ -f "$DEFAULT_PINNED_FILE" ]]; then
            cp "$DEFAULT_PINNED_FILE" "$PINNED_FILE"
        else
            {
                printf '# One desktop entry id or executable per line. First 3 valid entries appear at the top.\n'
                printf '# Use : in the launcher, then choose this action to edit the file again.\n'
            } > "$PINNED_FILE"
        fi
    fi
}

ensure_user_bang_file() {
    mkdir -p "$(dirname "$BANG_FILE")"
    if [[ ! -f "$BANG_FILE" ]]; then
        if [[ -f "$DEFAULT_BANG_FILE" ]]; then
            cp "$DEFAULT_BANG_FILE" "$BANG_FILE"
        else
            {
                printf 'return {\n'
                printf '  -- Add bang commands here.\n'
                printf '}\n'
            } > "$BANG_FILE"
        fi
    fi
}

open_text_file() {
    local path="$1"
    local editor="${DEFAULT_EDITOR_CMD%% *}"

    if [[ -n "$DEFAULT_EDITOR_CMD" ]]; then
        setsid "$editor" "$path" >/dev/null 2>&1 &
    elif command -v code >/dev/null 2>&1; then
        setsid code "$path" >/dev/null 2>&1 &
    elif command -v zed >/dev/null 2>&1; then
        setsid zed "$path" >/dev/null 2>&1 &
    else
        setsid xdg-open "$path" >/dev/null 2>&1 &
    fi
}

open_pinned_config() {
    ensure_user_pinned_file
    open_text_file "$PINNED_FILE"
}

open_bang_config() {
    ensure_user_bang_file
    open_text_file "$BANG_FILE"
}

open_config_target() {
    local path="$1"

    [[ -e "$path" ]] || {
        print_header "" "Config file not found: $path"
        print_notice "Use the repo template or create the live file first." "dialog-warning"
        return 0
    }

    open_text_file "$path"
}

open_config_in_editor() {
    local editor="$1"
    local -a targets=()
    local item path terminal="${TERMINAL:-ghostty}"

    for item in "${CONFIG_TARGETS[@]}"; do
        path="${item#*:}"
        [[ -e "$path" ]] && targets+=("$path")
    done

    if ((${#targets[@]} == 0)); then
        print_header "" "No config files found to open."
        print_notice "Create a live config file first or use the repo template." "dialog-warning"
        return 0
    fi

    case "$editor" in
        code)
            setsid code "${targets[@]}" >/dev/null 2>&1 &
            ;;
        zed)
            setsid zed "${targets[@]}" >/dev/null 2>&1 &
            ;;
        nvim|vim|nano)
            setsid "$terminal" -e "$editor" "${targets[@]}" >/dev/null 2>&1 &
            ;;
        *)
            print_header "" "Unknown editor '$editor'."
            print_notice "Use nvim, vim, code, zed, or nano." "dialog-warning"
            ;;
    esac
}

open_file() {
    local path="$1"

    if [[ -d "$path" ]]; then
        setsid "${FILE_MANAGER:-xdg-open}" "$path" >/dev/null 2>&1 &
    else
        setsid xdg-open "$path" >/dev/null 2>&1 &
    fi
}

run_bang_command() {
    local trigger="$1"
    local query="$2"
    local kind="${BANG_TYPE[$trigger]:-shell}"
    local template="${BANG_TEMPLATE[$trigger]:-}"
    local command url encoded_query quoted_query

    [[ -n "$template" ]] || {
        print_header "" "Bang command $trigger is missing a template."
        print_notice "Edit bang commands from the : menu." "dialog-warning"
        return 0
    }

    case "$kind" in
        url)
            encoded_query="$(url_encode "$query")"
            url="${template//\{query\}/$encoded_query}"
            setsid xdg-open "$url" >/dev/null 2>&1 &
            ;;
        terminal)
            quoted_query="$(shell_quote "$query")"
            command="${template//\{query\}/$quoted_query}"
            setsid "${TERMINAL:-ghostty}" -e sh -lc "$command" >/dev/null 2>&1 &
            ;;
        shell|command)
            quoted_query="$(shell_quote "$query")"
            command="${template//\{query\}/$quoted_query}"
            setsid sh -lc "$command" >/dev/null 2>&1 &
            ;;
        *)
            print_header "" "Unknown bang command type '$kind' for $trigger."
            print_notice "Use type = \"url\", \"shell\", or \"terminal\"." "dialog-warning"
            return 0
            ;;
    esac
}

handle_bang_query() {
    local query="$1"
    local trigger rest

    for trigger in "${BANG_TRIGGERS[@]}"; do
        if [[ "$query" == "$trigger" || "$query" == "$trigger "* ]]; then
            rest="${query#"$trigger"}"
            rest="${rest# }"
            run_bang_command "$trigger" "$rest"
            return 0
        fi
    done

    print_header "" "No bang command matched '$query'. Type : to edit or view bang commands."
    print_notice "Bang commands run after Enter and must be configured in $(user_path "$BANG_FILE")." "dialog-information"
}

handle_info() {
    local info="$1"
    local kind rest root query

    case "$info" in
        menu:commands)
            print_command_menu
            ;;
        menu:config)
            print_config_menu
            ;;
        menu:folders)
            print_folder_menu
            ;;
        hint:*)
            print_header "" "${info#hint:}"
            print_notice "Type the shown prefix or path in the search box, then press Enter." "dialog-information"
            ;;
        config:pinned)
            open_pinned_config
            ;;
        config:bangs)
            open_bang_config
            ;;
        config:file:*)
            open_config_target "${info#config:file:}"
            ;;
        config:editor:*)
            open_config_in_editor "${info#config:editor:}"
            ;;
        file:*)
            open_file "${info#file:}"
            ;;
        search:glob:*)
            rest="${info#search:glob:}"
            root="${rest%:*}"
            query="${rest##*:}"
            search_file_names "$root" "$query"
            ;;
        search:content:*)
            rest="${info#search:content:}"
            root="${rest%%:*}"
            query="${rest#*:}"
            search_file_contents "$root" "$query"
            ;;
        *)
            launch_app "$info"
            ;;
    esac
}

handle_custom_query() {
    local query="$1"
    local root pattern

    case "$query" in
        :config\ *)
            open_config_in_editor "${query#':config '}"
            ;;
        :config)
            print_config_menu
            ;;
        !*)
            handle_bang_query "$query"
            ;;
        :)
            print_command_menu
            ;;
        /)
            print_folder_menu
            ;;
        "~/"*)
            root="$HOME/${query#"~/"}"
            root="${root% *}"
            pattern="${query#* }"
            [[ "$pattern" != "$query" ]] || pattern="*"
            search_file_names "$root" "*$pattern*"
            ;;
        /*" "*)
            root="${query% *}"
            pattern="${query##* }"
            search_file_names "$root" "*$pattern*"
            ;;
        /*)
            search_file_names "$query" "*"
            ;;
        "**"?*)
            search_file_contents "$SEARCH_HOME" "${query:2}"
            ;;
        *'*'* | *'?'*)
            search_file_names "$SEARCH_HOME" "$query"
            ;;
        *)
            print_header "" "That did not run. Prefixes need Enter: !bang args, : commands, :config, /path term filenames, *.md filenames, **text contents."
            print_notice "Type : to open commands, or keep typing to filter apps live." "dialog-information"
            ;;
    esac
}

remember_app() {
    local id="$1"
    mkdir -p "$STATE_DIR"
    {
        printf '%s\n' "$id"
        [[ -f "$RECENT_FILE" ]] && grep -vxF "$id" "$RECENT_FILE" || true
    } | head -n "$MAX_RECENT" > "$RECENT_FILE.tmp"
    mv "$RECENT_FILE.tmp" "$RECENT_FILE"
}

launch_app() {
    local id="$1"
    local command="${APP_EXEC[$id]}"

    remember_app "$id"

    if command -v gtk-launch >/dev/null 2>&1; then
        gtk-launch "$id" >/dev/null 2>&1 &
        return 0
    fi

    if [[ "${APP_TERMINAL[$id]}" == "true" ]]; then
        "${TERMINAL:-ghostty}" -e sh -lc "$command" >/dev/null 2>&1 &
    else
        setsid sh -lc "$command" >/dev/null 2>&1 &
    fi
}

main() {
    load_launcher_config
    load_bang_commands
    load_apps

    if [[ "${1:-}" == "--mode" ]]; then
        shift

        if [[ -n "${ROFI_INFO:-}" ]]; then
            handle_info "$ROFI_INFO"
            return 0
        fi

        if [[ "${ROFI_RETV:-0}" == "2" ]]; then
            handle_custom_query "${*:-}"
            return 0
        fi

        print_rows
        return 0
    fi

    rofi \
        -show dotfiles-apps \
        -modes "dotfiles-apps:$SCRIPT_DIR/launcher --mode" \
        -theme "$THEME" \
        -show-icons \
        -matching fuzzy \
        -sorting-method fzf \
        -sort \
        -i \
        -p "" \
        -display-dotfiles-apps ""
}

main "$@"
