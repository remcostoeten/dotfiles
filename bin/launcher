#!/usr/bin/env bash
set -euo pipefail

if command -v fuzzel >/dev/null 2>&1; then
    exec fuzzel
fi

if command -v krunner >/dev/null 2>&1; then
    exec krunner
fi

if command -v gtk-launch >/dev/null 2>&1; then
    mapfile -t desktop_files < <(
        find "$HOME/.local/share/applications" /usr/local/share/applications /usr/share/applications \
            -type f -name '*.desktop' 2>/dev/null | sort
    )

    if ((${#desktop_files[@]} > 0)); then
        printf 'No graphical launcher found. Available desktop app ids:\n' >&2
        for path in "${desktop_files[@]}"; do
            basename "$path"
        done >&2
    fi
fi

if command -v gio >/dev/null 2>&1; then
    exec gio launch
fi

printf 'No app launcher found. Install fuzzel or use KDE krunner.\n' >&2
exit 1
