#!/usr/bin/env bash
# Clone or update the Turso DB creator and run the upstream generator.
set -euo pipefail

runner="$HOME/.config/dotfiles/scripts/lib/github-tool-runner.sh"

exec "$runner" \
    "https://github.com/remcostoeten/Turso-db-creator-auto-retrieve-env-credentials.git" \
    "turso-db-creator" \
    "generate-turso-db.py" \
    "$@"
