#!/usr/bin/env bash
set -euo pipefail

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly NC='\033[0m'

usage() {
    echo -e "${CYAN}Usage:${NC} kill [signal] <name|pid>"
    echo ""
    echo -e "${CYAN}Examples:${NC}"
    echo "  kill nginx          search and interactively kill nginx"
    echo "  kill -9 nginx       send SIGKILL to all nginx processes"
    echo "  kill 1234           pass PID through to real kill"
    echo "  kill -l             list signal names"
}

passthrough() {
    command kill "$@"
}

if [[ "${1:-}" == "-l" || "${1:-}" == "-L" ]]; then
    passthrough "$@"
    exit
fi

SIGNAL=""
ARGS=()
for arg in "$@"; do
    if [[ -z "$SIGNAL" && "$arg" =~ ^-([0-9]+|SIG[A-Za-z0-9]+)$ ]]; then
        SIGNAL="$arg"
    else
        ARGS+=("$arg")
    fi
done

TARGET="${ARGS[0]:-}"

if [[ -z "$TARGET" ]]; then
    usage
    exit 1
fi

if [[ "$TARGET" =~ ^[0-9]+$ ]]; then
    command kill $SIGNAL "$TARGET"
    exit
fi

kill_pid() {
    local pid=$1
    command kill $SIGNAL "$pid" 2>/dev/null || echo -e "${RED}Failed to kill PID $pid${NC}" >&2
}

pids=()

mapfile -t pids < <(pgrep -x "$TARGET" 2>/dev/null || true)

if [[ ${#pids[@]} -eq 0 ]]; then
    mapfile -t pids < <(pgrep -ix "$TARGET" 2>/dev/null || true)
fi

if [[ ${#pids[@]} -eq 0 ]]; then
    mapfile -t pids < <(pgrep -i "$TARGET" 2>/dev/null || true)
fi

if [[ ${#pids[@]} -eq 0 ]]; then
    all_procs=$(ps -eo comm= | sort -u)
    suggestions=$(echo "$all_procs" | grep -i "$TARGET" 2>/dev/null || true)

    if [[ -n "$suggestions" ]]; then
        echo -e "${YELLOW}No process matching '${TARGET}'. Did you mean:${NC}" >&2
        echo "$suggestions" | head -10 | while read -r s; do
            echo -e "  ${CYAN}$s${NC}" >&2
        done
    else
        echo -e "${RED}No process found matching '${TARGET}'${NC}" >&2
    fi
    exit 1
fi

declare -a names=()
for pid in "${pids[@]}"; do
    name=$(ps -p "$pid" -o comm= 2>/dev/null || echo "$TARGET")
    names+=("$name")
done

if [[ ${#pids[@]} -eq 1 ]]; then
    echo -e "${YELLOW}Killing ${CYAN}${names[0]}${YELLOW} (PID ${pids[0]})${NC}${SIGNAL:+ with signal $SIGNAL}" >&2
    kill_pid "${pids[0]}"
    exit
fi

echo -e "${YELLOW}Multiple processes match '${TARGET}':${NC}" >&2

if command -v fzf >/dev/null 2>&1; then
    choices=()
    for i in "${!pids[@]}"; do
        choices+=("${pids[$i]} ${names[$i]}")
    done
    selected=$(printf "%s\n" "${choices[@]}" | fzf --height=10 --header="Select processes to kill (TAB for multiple)" -m --preview='ps -fp {1}' 2>/dev/null || true)
    if [[ -z "$selected" ]]; then
        echo -e "${YELLOW}Cancelled${NC}" >&2
        exit 1
    fi
    while read -r line; do
        pid=$(echo "$line" | awk '{print $1}')
        if [[ -n "$pid" ]]; then
            kill_pid "$pid"
        fi
    done <<< "$selected"
else
    echo -e "${BOLD}  #  PID   PROCESS${NC}" >&2
    for i in "${!pids[@]}"; do
        printf "  %d) %-5s %s\n" $((i+1)) "${pids[$i]}" "${names[$i]}" >&2
    done
    echo "" >&2
    echo -e "Enter numbers (e.g. ${CYAN}1${NC}, ${CYAN}1,3${NC}, ${CYAN}all${NC}), or ${CYAN}q${NC} to quit: " >&2
    read -r selection

    if [[ "$selection" == "q" || "$selection" == "quit" ]]; then
        echo -e "${YELLOW}Cancelled${NC}" >&2
        exit 1
    fi

    if [[ "$selection" == "all" || "$selection" == "*" ]]; then
        for pid in "${pids[@]}"; do
            kill_pid "$pid"
        done
    else
        IFS=',' read -ra indices <<< "$selection"
        for idx in "${indices[@]}"; do
            idx=$((idx - 1))
            if [[ $idx -ge 0 && $idx -lt ${#pids[@]} ]]; then
                kill_pid "${pids[$idx]}"
            fi
        done
    fi
fi
