#!/usr/bin/env bash
set -euo pipefail

SINK3MM="alsa_output.pci-0000_00_1f.3.analog-stereo"
prev=$(pactl get-default-sink)

pactl set-default-sink "$SINK3MM"

"$@" &
cs2_pid=$!

while kill -0 "$cs2_pid" 2>/dev/null; do
  pactl list short sink-inputs 2>/dev/null | awk '{print $1}' | while read -r id; do
    pactl move-sink-input "$id" "$SINK3MM" 2>/dev/null || true
  done
  sleep 0.5
done 2>/dev/null

wait "$cs2_pid" 2>/dev/null || true
pactl set-default-sink "$prev"
