#!/usr/bin/env bash
set -euo pipefail

SINK1="alsa_output.usb-SteelSeries_SteelSeries_Arctis_7-00.stereo-game"
SINK2="alsa_output.pci-0000_00_1f.3.analog-stereo"

current=$(pactl get-default-sink)

if [[ "$current" == "$SINK1" ]]; then
  new="$SINK2"
  label="3.5mm Jack"
else
  new="$SINK1"
  label="SteelSeries Arctis 7"
fi

pactl set-default-sink "$new"

# Move all currently playing streams to the new sink
pactl list short sink-inputs 2>/dev/null | awk '{print $1}' | while read -r id; do
  pactl move-sink-input "$id" "$new" 2>/dev/null || true
done

notify-send -t 1500 "Audio: $label" 2>/dev/null || echo "Audio: $label"
