#!/usr/bin/env bash

entries="Power Off:poweroff
Restart:reboot
Go to BIOS:bios
Sleep:sleep
Logout / Change User:logout"

if command -v fuzzel >/dev/null 2>&1; then
  selected=$(printf '%s\n' "$entries" | fuzzel --dmenu --prompt "System " --lines 5 | awk -F: '{print $2}')
elif command -v kdialog >/dev/null 2>&1; then
  selected=$(kdialog --menu "System" \
    poweroff "Power Off" \
    reboot "Restart" \
    bios "Go to BIOS" \
    sleep "Sleep" \
    logout "Logout / Change User")
else
  printf '%s\n' "$entries" >&2
  printf 'Select action: ' >&2
  read -r selected
fi

# Execute the corresponding action
case $selected in
  poweroff)
    systemctl poweroff
    ;;
  reboot)
    systemctl reboot
    ;;
  bios)
    systemctl reboot --firmware-setup
    ;;
  sleep)
    systemctl suspend
    ;;
  logout)
    if command -v hyprctl >/dev/null 2>&1; then
      hyprctl dispatch exit
    else
      loginctl terminate-user "$USER"
    fi
    ;;
esac
