#!/bin/sh

set -eu

downloads_dir="${HOME}/Downloads"

# Prefer NVIDIA's video decode path and Chromium's Linux GPU features.
export LIBVA_DRIVER_NAME="${LIBVA_DRIVER_NAME:-nvidia}"
export NVD_BACKEND="${NVD_BACKEND:-direct}"
export VDPAU_DRIVER="${VDPAU_DRIVER:-nvidia}"

common_flags="
--use-gl=desktop
--ignore-gpu-blocklist
--enable-gpu-rasterization
--enable-zero-copy
--enable-features=VaapiVideoDecoder
--disable-features=UseChromeOSDirectVideoDecoder
"

app=$(
  find "$downloads_dir" -maxdepth 3 -type f \
    \( -iname '*helium*.AppImage' -o -iname 'Helium*.AppImage' -o -iname '*helium*' -o -iname 'Helium*' \) \
    | head -n 1
)

if [ -z "$app" ]; then
  printf 'Helium not found in %s\n' "$downloads_dir" >&2
  exit 1
fi

case "$app" in
  *.AppImage)
    chmod +x "$app" 2>/dev/null || true
    ;;
esac

if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
  exec env -u WAYLAND_DISPLAY \
    "$app" \
    --ozone-platform=x11 \
    $common_flags \
    "$@"
fi

exec "$app" $common_flags "$@"
