#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="${DOTFILES_DIR:-$HOME/.config/dotfiles}"
WALLPAPERS_DIR="$ROOT_DIR/configs/wallpapers"
MANIFEST_FILE="$WALLPAPERS_DIR/manifest.tsv"
CURRENT_LINK="$WALLPAPERS_DIR/current"
STATE_FILE="$WALLPAPERS_DIR/.current-wallpaper"
METADATA_FILE="$WALLPAPERS_DIR/.metadata.tsv"

USER_DATA_DIR="$HOME/.dotfiles/wallpaper"
UI_STATE_FILE="$USER_DATA_DIR/ui-state"
UI_MARKS_FILE="$USER_DATA_DIR/marks"
ROTATION_PID_FILE="$USER_DATA_DIR/rotation.pid"
ROTATION_INFO_FILE="$USER_DATA_DIR/rotation.info"
ROTATION_LOG_FILE="$USER_DATA_DIR/rotation.log"

SORT_MODE_DEFAULT="name"

WALLPAPER_NAMES=()
WALLPAPER_FILES=()
WALLPAPER_MODES=()
WALLPAPER_TAGS=()
WALLPAPER_SOURCES=()
WALLPAPER_AUTHORS=()
WALLPAPER_LICENSES=()

ensure_user_data_dir() {
    mkdir -p "$USER_DATA_DIR"
}

script_path() {
    readlink -f "${BASH_SOURCE[0]}"
}

rotation_pid() {
    [[ -f "$ROTATION_PID_FILE" ]] || return 1
    local pid
    pid="$(<"$ROTATION_PID_FILE")"
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "$pid"
}

rotation_process_matches() {
    local pid="$1"
    local cmdline=""

    if [[ -r "/proc/$pid/cmdline" ]]; then
        cmdline="$(tr '\0' ' ' < "/proc/$pid/cmdline")"
    else
        cmdline="$(ps -p "$pid" -o args= 2>/dev/null || true)"
    fi

    [[ "$cmdline" == *"__rotate-loop"* ]]
}

rotation_is_running() {
    local pid
    pid="$(rotation_pid)" || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    rotation_process_matches "$pid" || return 1
}

cleanup_rotation_state_if_stale() {
    rotation_is_running && return 0
    rm -f "$ROTATION_PID_FILE" "$ROTATION_INFO_FILE"
}

write_rotation_info() {
    local pid="$1"
    local duration="$2"
    local scope="$3"

    {
        printf 'pid=%s\n' "$pid"
        printf 'duration=%s\n' "$duration"
        printf 'scope=%s\n' "$scope"
        printf 'started_at=%s\n' "$(date '+%Y-%m-%d %H:%M:%S')"
    } > "$ROTATION_INFO_FILE"
}

rotation_info_value() {
    local key="$1"
    [[ -f "$ROTATION_INFO_FILE" ]] || return 1
    awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$ROTATION_INFO_FILE"
}

rotation_status() {
    local pid duration scope started current
    if rotation_is_running; then
        pid="$(rotation_pid)"
        duration="$(rotation_info_value duration || printf '?')"
        scope="$(rotation_info_value scope || printf 'all')"
        started="$(rotation_info_value started_at || printf '?')"
        current="$(current_wallpaper_name || true)"
        printf 'rotation running\n'
        printf 'pid: %s\n' "$pid"
        printf 'interval: %ss\n' "$duration"
        printf 'scope: %s\n' "$scope"
        printf 'started: %s\n' "$started"
        [[ -n "$current" ]] && printf 'current: %s\n' "$current"
    else
        cleanup_rotation_state_if_stale
        printf 'rotation stopped\n'
    fi
}

stop_rotation() {
    local pid
    if ! rotation_is_running; then
        cleanup_rotation_state_if_stale
        printf 'rotation is not running\n'
        return 0
    fi

    pid="$(rotation_pid)"
    kill "$pid" 2>/dev/null || true

    local waited=0
    while kill -0 "$pid" 2>/dev/null && (( waited < 30 )); do
        sleep 0.1
        ((waited += 1))
    done

    if kill -0 "$pid" 2>/dev/null; then
        kill -KILL "$pid" 2>/dev/null || true
    fi

    rm -f "$ROTATION_PID_FILE" "$ROTATION_INFO_FILE"
    printf 'stopped wallpaper rotation\n'
}

restore_terminal() {
    stty sane 2>/dev/null || true
    printf '\033[?25h'
}

die() {
    printf 'wallpaper: %s\n' "$1" >&2
    exit 1
}

require_file() {
    [[ -f "$1" ]] || die "missing file: $1"
}

normalize_relative_dir() {
    local value="${1:-}"
    value="${value#./}"
    value="${value#/}"
    value="${value%/}"

    [[ "$value" == "." ]] && value=""
    [[ "$value" == ".." ]] && return 1
    [[ "$value" == *"/../"* ]] && return 1
    [[ "$value" == ../* ]] && return 1

    printf '%s\n' "$value"
}

image_extension_from_url() {
    local url="$1"
    local clean_url ext

    clean_url="${url%%\?*}"
    clean_url="${clean_url%%\#*}"
    ext="${clean_url##*.}"
    ext="$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"

    case "$ext" in
        jpg|jpeg|png|webp)
            printf '%s\n' "$ext"
            ;;
        *)
            return 1
            ;;
    esac
}

download_filename_from_url() {
    local url="$1"
    local fallback_ext="$2"
    local clean_url filename

    clean_url="${url%%\?*}"
    clean_url="${clean_url%%\#*}"
    filename="${clean_url##*/}"

    if [[ -z "$filename" ]] || [[ "$filename" == "$clean_url" ]]; then
        printf 'downloaded_%s.%s\n' "$(date +%s)" "$fallback_ext"
    else
        printf '%s\n' "$filename"
    fi
}

compose_wallpaper_name() {
    local group="${1:-}"
    local label="$2"

    if [[ -n "$group" ]] && [[ "$group" != "." ]]; then
        printf '%s/%s\n' "$group" "$label"
    else
        printf '%s\n' "$label"
    fi
}

label_with_suffix() {
    local label="$1"
    local suffix="$2"
    printf '%s-%s\n' "$label" "$suffix"
}

read_manifest() {
    require_file "$MANIFEST_FILE"

    WALLPAPER_NAMES=()
    WALLPAPER_FILES=()
    WALLPAPER_MODES=()
    WALLPAPER_TAGS=()
    WALLPAPER_SOURCES=()
    WALLPAPER_AUTHORS=()
    WALLPAPER_LICENSES=()

    while IFS=$'\t' read -r name file mode; do
        [[ -z "${name:-}" ]] && continue
        [[ "${name#\#}" != "$name" ]] && continue
        [[ -z "${file:-}" ]] && continue
        WALLPAPER_NAMES+=("$name")
        WALLPAPER_FILES+=("$file")
        WALLPAPER_MODES+=("${mode:-fill}")
        WALLPAPER_TAGS+=("")
        WALLPAPER_SOURCES+=("")
        WALLPAPER_AUTHORS+=("")
        WALLPAPER_LICENSES+=("")
    done < "$MANIFEST_FILE"

    if [[ -f "$METADATA_FILE" ]]; then
        while IFS=$'\t' read -r name tags source author license; do
            [[ -z "${name:-}" ]] && continue
            [[ "${name#\#}" != "$name" ]] && continue
            if idx="$(resolve_index "$name" 2>/dev/null)"; then
                WALLPAPER_TAGS[$idx]="${tags:-}"
                WALLPAPER_SOURCES[$idx]="${source:-}"
                WALLPAPER_AUTHORS[$idx]="${author:-}"
                WALLPAPER_LICENSES[$idx]="${license:-}"
            fi
        done < "$METADATA_FILE"
    fi
}

write_manifest() {
    local tmp
    local i

    tmp="$(mktemp)"
    printf '# name\tfile\tmode\n' > "$tmp"
    for i in "${!WALLPAPER_NAMES[@]}"; do
        printf '%s\t%s\t%s\n' "${WALLPAPER_NAMES[$i]}" "${WALLPAPER_FILES[$i]}" "${WALLPAPER_MODES[$i]}" >> "$tmp"
    done
    mv "$tmp" "$MANIFEST_FILE"
}

write_metadata() {
    local tmp i
    tmp="$(mktemp)"
    printf '# name\ttags\tsource\tauthor\tlicense\n' > "$tmp"
    for i in "${!WALLPAPER_NAMES[@]}"; do
        printf '%s\t%s\t%s\t%s\t%s\n' \
            "${WALLPAPER_NAMES[$i]}" \
            "${WALLPAPER_TAGS[$i]}" \
            "${WALLPAPER_SOURCES[$i]}" \
            "${WALLPAPER_AUTHORS[$i]}" \
            "${WALLPAPER_LICENSES[$i]}" >> "$tmp"
    done
    mv "$tmp" "$METADATA_FILE"
}

resolve_index() {
    local wanted="$1"
    local i

    for i in "${!WALLPAPER_NAMES[@]}"; do
        if [[ "${WALLPAPER_NAMES[$i]}" == "$wanted" ]]; then
            printf '%s\n' "$i"
            return 0
        fi
    done

    return 1
}

wallpaper_group_by_name() {
    local name="$1"
    if [[ "$name" == */* ]]; then
        printf '%s\n' "${name%/*}"
    else
        printf '.\n'
    fi
}

wallpaper_group() {
    wallpaper_group_by_name "${WALLPAPER_NAMES[$1]}"
}

wallpaper_label() {
    local idx="$1"
    printf '%s\n' "${WALLPAPER_NAMES[$idx]##*/}"
}

wallpaper_path() {
    local idx="$1"
    printf '%s/%s\n' "$WALLPAPERS_DIR" "${WALLPAPER_FILES[$idx]}"
}

active_name() {
    local target
    local i

    target="$(readlink -f "$CURRENT_LINK" 2>/dev/null || true)"
    [[ -n "$target" ]] || return 1

    for i in "${!WALLPAPER_FILES[@]}"; do
        if [[ "$(readlink -f "$(wallpaper_path "$i")")" == "$target" ]]; then
            printf '%s\n' "${WALLPAPER_NAMES[$i]}"
            return 0
        fi
    done

    return 1
}

current_wallpaper_name() {
    active_name 2>/dev/null || cat "$STATE_FILE" 2>/dev/null || true
}

start_wallpaper() {
    local mode="$1"
    pkill -x swaybg >/dev/null 2>&1 || true
    nohup swaybg -i "$CURRENT_LINK" -m "$mode" >/dev/null 2>&1 &
}

set_wallpaper() {
    local name="$1"
    local idx
    idx="$(resolve_index "$name")" || die "unknown wallpaper: $name"

    ln -sfn "$(wallpaper_path "$idx")" "$CURRENT_LINK"
    printf '%s\n' "$name" > "$STATE_FILE"
    start_wallpaper "${WALLPAPER_MODES[$idx]}"
    printf 'set %s\n' "$name"
}

open_wallpapers_dir() {
    xdg-open "$WALLPAPERS_DIR" >/dev/null 2>&1 &
}

all_folder_paths() {
    if [[ -d "$WALLPAPERS_DIR" ]]; then
        find "$WALLPAPERS_DIR" -mindepth 1 -type d -printf '%P\n' | sort
    fi
}

parent_folder() {
    local dir="$1"
    [[ -z "$dir" || "$dir" == "." ]] && {
        printf '\n'
        return
    }
    if [[ "$dir" == */* ]]; then
        printf '%s\n' "${dir%/*}"
    else
        printf '\n'
    fi
}

is_folder_known() {
    local dir="$1"
    [[ -z "$dir" || "$dir" == "." ]] && return 0
    [[ -d "$WALLPAPERS_DIR/$dir" ]]
}

cleanup_empty_parent_dirs() {
    local rel="$1"
    local dir

    dir="$(dirname "$rel")"
    while [[ "$dir" != "." && -n "$dir" ]]; do
        rmdir "$WALLPAPERS_DIR/$dir" 2>/dev/null || break
        dir="$(dirname "$dir")"
    done
}

wallpaper_mtime() {
    local idx="$1"
    stat -c '%Y' "$(wallpaper_path "$idx")" 2>/dev/null || printf '0\n'
}

file_size_human() {
    local path="$1"
    local bytes
    bytes="$(stat -c '%s' "$path" 2>/dev/null || printf '0')"
    if command -v numfmt >/dev/null 2>&1; then
        numfmt --to=iec-i --suffix=B "$bytes"
    else
        printf '%sB\n' "$bytes"
    fi
}

file_mtime_human() {
    local path="$1"
    local epoch
    epoch="$(stat -c '%Y' "$path" 2>/dev/null || printf '0')"
    if [[ "$epoch" == "0" ]]; then
        printf 'unknown\n'
    else
        date -d "@$epoch" '+%Y-%m-%d %H:%M'
    fi
}

csv_join_spaces() {
    local value="${1:-}"
    printf '%s\n' "${value//,/ }" | tr -s ' ' | sed 's/^ *//; s/ *$//'
}

normalize_tags() {
    local value="${1:-}"
    value="$(printf '%s' "$value" | tr ';' ',' | tr '[:upper:]' '[:lower:]')"
    value="${value// /,}"
    value="${value//,,/,}"
    value="${value#,}"
    value="${value%,}"
    printf '%s\n' "$value"
}

has_tag() {
    local tags="${1:-}" wanted="${2:-}"
    IFS=',' read -r -a parts <<< "$tags"
    local part
    for part in "${parts[@]}"; do
        [[ -n "$part" ]] || continue
        [[ "$part" == "$wanted" ]] && return 0
    done
    return 1
}

matches_text_filter() {
    local haystack="${1:-}" needle="${2:-}"
    [[ -z "$needle" ]] && return 0
    [[ "${haystack,,}" == *"${needle,,}"* ]]
}

wallpaper_metadata_summary() {
    local idx="$1"
    local tags="${WALLPAPER_TAGS[$idx]:-}"
    local source="${WALLPAPER_SOURCES[$idx]:-}"
    local author="${WALLPAPER_AUTHORS[$idx]:-}"
    local license="${WALLPAPER_LICENSES[$idx]:-}"
    printf 'tags=%s source=%s author=%s license=%s\n' "${tags:-none}" "${source:-none}" "${author:-none}" "${license:-none}"
}

update_wallpaper_metadata() {
    local idx="$1"
    local tags="${2:-${WALLPAPER_TAGS[$idx]:-}}"
    local source="${3:-${WALLPAPER_SOURCES[$idx]:-}}"
    local author="${4:-${WALLPAPER_AUTHORS[$idx]:-}}"
    local license="${5:-${WALLPAPER_LICENSES[$idx]:-}}"
    WALLPAPER_TAGS[$idx]="$tags"
    WALLPAPER_SOURCES[$idx]="$source"
    WALLPAPER_AUTHORS[$idx]="$author"
    WALLPAPER_LICENSES[$idx]="$license"
}

import_local_wallpaper() {
    local source_path="$1"
    shift
    local folder="" name="" tags="" source="" author="" license="" ext filename target_rel target_abs manifest_name

    while (($#)); do
        case "$1" in
            --folder)
                folder="${2:-}"
                shift 2
                ;;
            --name)
                name="${2:-}"
                shift 2
                ;;
            --tags)
                tags="$(normalize_tags "${2:-}")"
                shift 2
                ;;
            --source)
                source="${2:-}"
                shift 2
                ;;
            --author)
                author="${2:-}"
                shift 2
                ;;
            --license)
                license="${2:-}"
                shift 2
                ;;
            *)
                die "unknown import option: $1"
                ;;
        esac
    done

    [[ -f "$source_path" ]] || die "missing file: $source_path"
    ext="${source_path##*.}"
    ext="$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"
    case "$ext" in
        jpg|jpeg|png|webp) ;;
        *) die "only .jpg, .jpeg, .png, and .webp files are supported" ;;
    esac
    folder="$(normalize_relative_dir "$folder")" || die "invalid folder path"
    filename="$(basename "$source_path")"
    target_rel="$filename"
    [[ -n "$folder" ]] && target_rel="$folder/$filename"
    target_rel="$(unique_relative_path "$target_rel")"
    target_abs="$WALLPAPERS_DIR/$target_rel"
    mkdir -p "$(dirname "$target_abs")"
    cp "$source_path" "$target_abs"
    [[ -n "$name" ]] || name="${filename%.*}"
    [[ -n "$source" ]] || source="$source_path"
    manifest_name="$(unique_manifest_name "$folder" "$name")"
    printf '%s\t%s\tfill\n' "$manifest_name" "$target_rel" >> "$MANIFEST_FILE"
    WALLPAPER_NAMES+=("$manifest_name")
    WALLPAPER_FILES+=("$target_rel")
    WALLPAPER_MODES+=("fill")
    WALLPAPER_TAGS+=("$tags")
    WALLPAPER_SOURCES+=("$source")
    WALLPAPER_AUTHORS+=("$author")
    WALLPAPER_LICENSES+=("$license")
    write_metadata
    printf 'imported %s -> %s\n' "$manifest_name" "$target_rel"
}

import_wallpaper_target() {
    local target="$1"
    shift
    if [[ -d "$target" ]]; then
        local file
        shopt -s nullglob
        for file in "$target"/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}; do
            [[ -e "$file" ]] || continue
            import_local_wallpaper "$file" "$@" || true
        done
        shopt -u nullglob
        return 0
    fi
    if [[ "$target" =~ ^https?:// ]]; then
        download_wallpaper_noninteractive "$target" "$@"
        return 0
    fi
    import_local_wallpaper "$target" "$@"
}

image_dimensions() {
    local path="$1"
    if command -v identify >/dev/null 2>&1; then
        identify -format '%wx%h' "$path" 2>/dev/null || printf 'unknown\n'
    else
        printf 'unknown\n'
    fi
}

mime_type() {
    local path="$1"
    if command -v file >/dev/null 2>&1; then
        file --brief --mime-type "$path" 2>/dev/null || printf 'unknown\n'
    else
        printf 'unknown\n'
    fi
}

load_ui_state() {
    UI_LAST_FOLDER=""
    UI_SORT_MODE="$SORT_MODE_DEFAULT"
    ensure_user_data_dir

    if [[ -f "$UI_STATE_FILE" ]]; then
        # shellcheck disable=SC1090
        source "$UI_STATE_FILE"
    fi

    UI_LAST_FOLDER="$(normalize_relative_dir "${UI_LAST_FOLDER:-}" || printf '')"
    [[ -n "$UI_SORT_MODE" ]] || UI_SORT_MODE="$SORT_MODE_DEFAULT"
}

save_ui_state() {
    ensure_user_data_dir
    cat > "$UI_STATE_FILE" <<EOF
UI_LAST_FOLDER=${UI_LAST_FOLDER:-}
UI_SORT_MODE=${UI_SORT_MODE:-$SORT_MODE_DEFAULT}
EOF
}

load_mark_names() {
    MARKED_NAMES=()
    ensure_user_data_dir
    if [[ -f "$UI_MARKS_FILE" ]]; then
        while IFS= read -r line; do
            [[ -n "$line" ]] && MARKED_NAMES["$line"]=1
        done < "$UI_MARKS_FILE"
    fi
}

save_mark_names() {
    local name
    ensure_user_data_dir
    : > "$UI_MARKS_FILE"
    for name in "${!MARKED_NAMES[@]}"; do
        printf '%s\n' "$name"
    done | sort > "$UI_MARKS_FILE"
}

prune_mark_names() {
    local name
    local -A seen=()
    for name in "${WALLPAPER_NAMES[@]}"; do
        seen["$name"]=1
    done
    for name in "${!MARKED_NAMES[@]}"; do
        [[ -n "${seen[$name]+x}" ]] || unset 'MARKED_NAMES[$name]'
    done
}

sorted_wallpaper_indices() {
    local mode="${1:-$SORT_MODE_DEFAULT}"
    local i group path epoch

    for i in "${!WALLPAPER_NAMES[@]}"; do
        case "$mode" in
            folder)
                group="$(wallpaper_group "$i")"
                printf '%s\t%s\t%04d\n' "$group" "$(wallpaper_label "$i")" "$i"
                ;;
            recent)
                epoch="$(wallpaper_mtime "$i")"
                printf '%s\t%04d\n' "$((9999999999 - epoch))" "$i"
                ;;
            *)
                printf '%s\t%04d\n' "${WALLPAPER_NAMES[$i]}" "$i"
                ;;
        esac
    done | sort | awk -F '\t' '{print $NF}'
}

cycle_sort_mode() {
    case "${UI_SORT_MODE:-$SORT_MODE_DEFAULT}" in
        name) UI_SORT_MODE="folder" ;;
        folder) UI_SORT_MODE="recent" ;;
        *) UI_SORT_MODE="name" ;;
    esac
}

unique_manifest_name() {
    local folder="$1"
    local wanted_label="$2"
    local candidate suffix=2

    candidate="$(compose_wallpaper_name "$folder" "$wanted_label")"
    while resolve_index "$candidate" >/dev/null 2>&1; do
        candidate="$(compose_wallpaper_name "$folder" "$(label_with_suffix "$wanted_label" "$suffix")")"
        ((suffix += 1))
    done
    printf '%s\n' "$candidate"
}

unique_relative_path() {
    local wanted="$1"
    local dir base stem ext candidate suffix=2

    dir="$(dirname "$wanted")"
    base="$(basename "$wanted")"
    stem="$base"
    ext=""
    if [[ "$base" == *.* ]]; then
        stem="${base%.*}"
        ext=".${base##*.}"
    fi

    candidate="$wanted"
    while [[ -e "$WALLPAPERS_DIR/$candidate" ]]; do
        if [[ "$dir" == "." ]]; then
            candidate="$(label_with_suffix "$stem" "$suffix")$ext"
        else
            candidate="$dir/$(label_with_suffix "$stem" "$suffix")$ext"
        fi
        ((suffix += 1))
    done
    printf '%s\n' "$candidate"
}

list_wallpapers() {
    local active sort_mode folder_filter tag_filter query_filter idx
    active="$(active_name 2>/dev/null || true)"
    sort_mode="${1:-$SORT_MODE_DEFAULT}"
    folder_filter="${2:-}"
    tag_filter="${3:-}"
    query_filter="${4:-}"

    while IFS= read -r idx; do
        if [[ -n "$folder_filter" ]]; then
            [[ "$(wallpaper_group "$idx")" == "$folder_filter" ]] || continue
        fi
        if [[ -n "$tag_filter" ]]; then
            has_tag "${WALLPAPER_TAGS[$idx]:-}" "$tag_filter" || continue
        fi
        if [[ -n "$query_filter" ]]; then
            matches_text_filter "${WALLPAPER_NAMES[$idx]} ${WALLPAPER_FILES[$idx]} ${WALLPAPER_TAGS[$idx]} ${WALLPAPER_SOURCES[$idx]} ${WALLPAPER_AUTHORS[$idx]} ${WALLPAPER_LICENSES[$idx]}" "$query_filter" || continue
        fi
        if [[ "${WALLPAPER_NAMES[$idx]}" == "$active" ]]; then
            printf '* %s -> %s (%s) [%s]\n' "${WALLPAPER_NAMES[$idx]}" "${WALLPAPER_FILES[$idx]}" "${WALLPAPER_MODES[$idx]}" "${WALLPAPER_TAGS[$idx]:-none}"
        else
            printf '  %s -> %s (%s) [%s]\n' "${WALLPAPER_NAMES[$idx]}" "${WALLPAPER_FILES[$idx]}" "${WALLPAPER_MODES[$idx]}" "${WALLPAPER_TAGS[$idx]:-none}"
        fi
    done < <(sorted_wallpaper_indices "$sort_mode")
}

random_wallpaper() {
    local count idx
    count="${#WALLPAPER_NAMES[@]}"
    (( count > 0 )) || die "no wallpapers in manifest"
    idx=$((RANDOM % count))
    set_wallpaper "${WALLPAPER_NAMES[$idx]}"
}

pick_random_from_names() {
    local -a names=("$@")
    local count idx
    count="${#names[@]}"
    (( count > 0 )) || return 1
    idx=$((RANDOM % count))
    printf '%s\n' "${names[$idx]}"
}

wallpaper_names_for_folder() {
    local folder="${1:-}"
    local idx
    for idx in "${!WALLPAPER_NAMES[@]}"; do
        if [[ -z "$folder" ]]; then
            [[ "$(wallpaper_group "$idx")" == "." ]] && printf '%s\n' "${WALLPAPER_NAMES[$idx]}"
        else
            [[ "$(wallpaper_group "$idx")" == "$folder" ]] && printf '%s\n' "${WALLPAPER_NAMES[$idx]}"
        fi
    done
}

random_rotation_loop() {
    local duration="$1"
    shift
    local -a pool=("$@")
    local current next count=0
    local last=""
    local sleep_pid=""

    (( duration > 0 )) || die "duration must be greater than 0"
    trap '[[ -n "${sleep_pid:-}" ]] && kill "$sleep_pid" 2>/dev/null || true; rm -f "$ROTATION_PID_FILE" "$ROTATION_INFO_FILE"; exit 0' INT TERM
    while true; do
        next="$(pick_random_from_names "${pool[@]}")" || die "no wallpapers available for the selected scope"
        if [[ "${#pool[@]}" -gt 1 ]]; then
            while [[ "$next" == "$last" ]]; do
                next="$(pick_random_from_names "${pool[@]}")" || break
            done
        fi
        set_wallpaper "$next"
        last="$next"
        ((count += 1))
        printf 'rotation %s in %s seconds (Ctrl-C to stop)\n' "$count" "$duration"
        sleep "$duration" &
        sleep_pid="$!"
        wait "$sleep_pid"
        sleep_pid=""
    done
}

start_rotation_daemon() {
    local duration="$1"
    local scope="$2"
    shift 2
    local -a pool=("$@")
    local pid

    cleanup_rotation_state_if_stale
    if rotation_is_running; then
        pid="$(rotation_pid)"
        die "rotation already running with pid $pid. Use 'wallpaper stop' first"
    fi

    : > "$ROTATION_LOG_FILE"
    nohup "$(script_path)" __rotate-loop "$duration" "${pool[@]}" >> "$ROTATION_LOG_FILE" 2>&1 < /dev/null &
    pid="$!"
    printf '%s\n' "$pid" > "$ROTATION_PID_FILE"
    write_rotation_info "$pid" "$duration" "$scope"

    printf 'started wallpaper rotation\n'
    printf 'pid: %s\n' "$pid"
    printf 'interval: %ss\n' "$duration"
    printf 'scope: %s\n' "$scope"
    printf 'log: %s\n' "$ROTATION_LOG_FILE"
}

prompt_radio_choice() {
    local title="$1"
    local message="$2"
    shift 2
    local -a options=("$@")
    local selected=0 key tty_device="/dev/tty"
    [[ -c "$tty_device" ]] || tty_device="/dev/stdout"
    stty sane 2>/dev/null || true
    printf '\033[?25h' > "$tty_device"
    while true; do
        clear > "$tty_device"
        printf '\n\033[1m%s\033[0m\n\n%s\n\n' "$title" "$message" > "$tty_device"
        for i in "${!options[@]}"; do
            if [[ "$i" -eq "$selected" ]]; then
                printf '  \033[38;5;110m›\033[0m \033[1m%s\033[0m\n' "${options[$i]}" > "$tty_device"
            else
                printf '  \033[2m·\033[0m %s\n' "${options[$i]}" > "$tty_device"
            fi
        done
        printf '\n\033[2mUse ↑↓ to choose • Enter to confirm • q to cancel\033[0m\n' > "$tty_device"
        IFS= read -r -s -n 1 key < "$tty_device"
        case "$key" in
            "")
                printf '%s\n' "${options[$selected]}"
                return 0
                ;;
            q|$'\x7f')
                return 1
                ;;
            $'\e')
                IFS= read -r -s -n 1 -t 0.1 key < "$tty_device"
                if [[ "$key" == "[" ]]; then
                    IFS= read -r -s -n 1 -t 0.1 key < "$tty_device"
                    [[ "$key" == "A" ]] && (( selected > 0 )) && ((selected -= 1))
                    [[ "$key" == "B" ]] && (( selected < ${#options[@]} - 1 )) && ((selected += 1))
                fi
                ;;
        esac
    done
}

random_wallpaper_interactive() {
    local scope folder duration scope_choice rotation_scope
    local -a names=()

    scope_choice="$(prompt_radio_choice "Random Wallpaper" "Choose what the randomizer should use." \
        "All wallpapers" \
        "Current selection / marks" \
        "A folder")" || return 0

    case "$scope_choice" in
        "All wallpapers")
            rotation_scope="all"
            while IFS= read -r scope; do
                [[ -n "$scope" ]] && names+=("$scope")
            done < <(printf '%s\n' "${WALLPAPER_NAMES[@]}")
            ;;
        "Current selection / marks")
            rotation_scope="selection"
            while IFS= read -r scope; do
                [[ -n "$scope" ]] && names+=("$scope")
            done < <(marked_or_selected_names)
            ;;
        "A folder")
            folder="$(prompt_select_folder "Choose Random Folder" "$UI_LAST_FOLDER")" || return 0
            folder="$(normalize_relative_dir "$folder")" || return 0
            rotation_scope="${folder:-root}"
            while IFS= read -r scope; do
                [[ -n "$scope" ]] && names+=("$scope")
            done < <(wallpaper_names_for_folder "$folder")
            ;;
    esac

    [[ ${#names[@]} -gt 0 ]] || {
        prompt_message "Random Wallpaper" "No wallpapers found for that scope."
        return 0
    }

    duration="$(prompt_input "Random Wallpaper" "Swap every how many seconds?" "60")"
    [[ "$duration" =~ ^[0-9]+$ ]] || {
        prompt_message "Random Wallpaper" "Duration must be a whole number of seconds."
        return 0
    }
    (( duration > 0 )) || {
        prompt_message "Random Wallpaper" "Duration must be greater than zero."
        return 0
    }

    cleanup_rotation_state_if_stale
    if rotation_is_running; then
        prompt_message "Random Wallpaper" "Rotation is already running.\n\nUse wallpaper stop, wallpaper --stop, or wallpaper -s to stop it first."
        return 0
    fi

    start_rotation_daemon "$duration" "$rotation_scope" "${names[@]}" >/dev/null
    prompt_message "Random Wallpaper" "Started random rotation in the background.\n\nScope: $scope_choice\nCount: ${#names[@]}\nInterval: ${duration}s\n\nUse wallpaper status to check it.\nUse wallpaper stop, wallpaper --stop, or wallpaper -s to stop it."
}

next_wallpaper() {
    local current idx next
    current="$(current_wallpaper_name)"

    if [[ -z "$current" ]]; then
        set_wallpaper "${WALLPAPER_NAMES[0]}"
        return 0
    fi

    idx="$(resolve_index "$current")" || idx=0
    next=$(( (idx + 1) % ${#WALLPAPER_NAMES[@]} ))
    set_wallpaper "${WALLPAPER_NAMES[$next]}"
}

prev_wallpaper() {
    local current idx prev
    current="$(current_wallpaper_name)"

    if [[ -z "$current" ]]; then
        set_wallpaper "${WALLPAPER_NAMES[0]}"
        return 0
    fi

    idx="$(resolve_index "$current")" || idx=0
    prev=$(( (idx - 1 + ${#WALLPAPER_NAMES[@]}) % ${#WALLPAPER_NAMES[@]} ))
    set_wallpaper "${WALLPAPER_NAMES[$prev]}"
}

mkdir_wallpaper_dir() {
    local dir
    dir="$(normalize_relative_dir "${1:-}")" || die "invalid folder path"
    [[ -n "$dir" ]] || die "folder path required"
    mkdir -p "$WALLPAPERS_DIR/$dir"
    printf 'created %s/\n' "$dir"
}

move_wallpaper_items() {
    local target_dir="$1"
    shift
    local name idx old_path target_rel target_abs active old_group label new_name
    local moved=0

    target_dir="$(normalize_relative_dir "$target_dir")" || die "invalid folder path"
    for name in "$@"; do
        idx="$(resolve_index "$name")" || die "unknown wallpaper: $name"
        old_path="${WALLPAPER_FILES[$idx]}"
        old_group="$(wallpaper_group "$idx")"
        label="$(wallpaper_label "$idx")"
        target_rel="${WALLPAPER_FILES[$idx]##*/}"
        [[ -n "$target_dir" ]] && target_rel="$target_dir/$target_rel"
        target_rel="$(unique_relative_path "$target_rel")"
        target_abs="$WALLPAPERS_DIR/$target_rel"
        mkdir -p "$(dirname "$target_abs")"
        mv "$WALLPAPERS_DIR/$old_path" "$target_abs"

        WALLPAPER_FILES[$idx]="$target_rel"
        new_name="$(unique_manifest_name "$target_dir" "$label")"
        WALLPAPER_NAMES[$idx]="$new_name"

        active=0
        [[ "$(current_wallpaper_name)" == "$name" ]] && active=1
        if (( active )); then
            ln -sfn "$target_abs" "$CURRENT_LINK"
            printf '%s\n' "$new_name" > "$STATE_FILE"
            start_wallpaper "${WALLPAPER_MODES[$idx]}"
        fi

        cleanup_empty_parent_dirs "$old_path"
        ((moved += 1))
    done

    write_manifest
    write_metadata
    printf 'moved %s wallpaper(s)\n' "$moved"
}

rename_wallpaper_item() {
    local old_name="$1"
    local new_label="$2"
    shift 2
    local new_file="" new_folder=""
    local idx old_rel old_abs ext target_rel target_abs target_name active=0

    while (($#)); do
        case "$1" in
            --file)
                new_file="${2:-}"
                shift 2
                ;;
            --folder)
                new_folder="${2:-}"
                shift 2
                ;;
            *)
                die "unknown rename option: $1"
                ;;
        esac
    done

    idx="$(resolve_index "$old_name")" || die "unknown wallpaper: $old_name"
    old_rel="${WALLPAPER_FILES[$idx]}"
    old_abs="$WALLPAPERS_DIR/$old_rel"
    [[ -n "$new_label" ]] || die "new wallpaper name required"

    if [[ -z "$new_folder" ]]; then
        new_folder="$(wallpaper_group "$idx")"
        [[ "$new_folder" == "." ]] && new_folder=""
    else
        new_folder="$(normalize_relative_dir "$new_folder")" || die "invalid folder path"
    fi

    if [[ -z "$new_file" ]]; then
        new_file="$(basename "$old_rel")"
    fi
    [[ "$new_file" == */* ]] && die "file name cannot contain '/'"

    target_rel="$new_file"
    [[ -n "$new_folder" ]] && target_rel="$new_folder/$new_file"
    if [[ "$target_rel" != "$old_rel" ]]; then
        target_rel="$(unique_relative_path "$target_rel")"
    fi

    target_name="$(compose_wallpaper_name "$new_folder" "$new_label")"
    if [[ "$target_name" != "$old_name" ]]; then
        target_name="$(unique_manifest_name "$new_folder" "$new_label")"
    fi

    target_abs="$WALLPAPERS_DIR/$target_rel"
    if [[ "$target_rel" != "$old_rel" ]]; then
        mkdir -p "$(dirname "$target_abs")"
        mv "$old_abs" "$target_abs"
        cleanup_empty_parent_dirs "$old_rel"
    fi

    [[ "$(current_wallpaper_name)" == "$old_name" ]] && active=1

    WALLPAPER_FILES[$idx]="$target_rel"
    WALLPAPER_NAMES[$idx]="$target_name"
    write_manifest
    write_metadata

    if (( active )); then
        ln -sfn "$target_abs" "$CURRENT_LINK"
        printf '%s\n' "$target_name" > "$STATE_FILE"
        start_wallpaper "${WALLPAPER_MODES[$idx]}"
    fi

    printf 'renamed %s -> %s\n' "$old_name" "$target_name"
}

delete_wallpaper_items() {
    local name idx path active=0
    local -a touched=()

    for name in "$@"; do
        idx="$(resolve_index "$name")" || die "unknown wallpaper: $name"
        path="$(wallpaper_path "$idx")"
        touched+=("${WALLPAPER_FILES[$idx]}")
        [[ "$(current_wallpaper_name)" == "$name" ]] && active=1
        rm -f "$path"
        unset 'WALLPAPER_NAMES[$idx]'
        unset 'WALLPAPER_FILES[$idx]'
        unset 'WALLPAPER_MODES[$idx]'
    done

    WALLPAPER_NAMES=("${WALLPAPER_NAMES[@]}")
    WALLPAPER_FILES=("${WALLPAPER_FILES[@]}")
    WALLPAPER_MODES=("${WALLPAPER_MODES[@]}")
    write_manifest
    write_metadata

    for path in "${touched[@]}"; do
        cleanup_empty_parent_dirs "$path"
    done

    if (( active )); then
        rm -f "$CURRENT_LINK" "$STATE_FILE"
    fi

    printf 'deleted %s wallpaper(s)\n' "$#"
}

download_wallpaper_noninteractive() {
    local url="$1"
    shift
    local folder="" name="" tags="" source="" author="" license="" ext filename target_rel target_abs manifest_name

    while (($#)); do
        case "$1" in
            --folder)
                folder="${2:-}"
                shift 2
                ;;
            --name)
                name="${2:-}"
                shift 2
                ;;
            --tags)
                tags="$(normalize_tags "${2:-}")"
                shift 2
                ;;
            --source)
                source="${2:-}"
                shift 2
                ;;
            --author)
                author="${2:-}"
                shift 2
                ;;
            --license)
                license="${2:-}"
                shift 2
                ;;
            *)
                die "unknown download option: $1"
                ;;
        esac
    done

    ext="$(image_extension_from_url "$url" 2>/dev/null || true)"
    if [[ -z "$ext" ]]; then
        local mime
        mime="$(curl -fsSLI "$url" | awk -F': ' 'BEGIN{IGNORECASE=1} /^content-type:/ {print $2}' | tail -n1 | tr -d '\r' | cut -d';' -f1)"
        case "$mime" in
            image/jpeg) ext="jpg" ;;
            image/png) ext="png" ;;
            image/webp) ext="webp" ;;
        esac
    fi
    [[ -n "$ext" ]] || die "could not determine image type from URL"
    folder="$(normalize_relative_dir "$folder")" || die "invalid folder path"
    filename="$(download_filename_from_url "$url" "$ext")"
    target_rel="$filename"
    [[ -n "$folder" ]] && target_rel="$folder/$filename"
    target_rel="$(unique_relative_path "$target_rel")"
    target_abs="$WALLPAPERS_DIR/$target_rel"
    mkdir -p "$(dirname "$target_abs")"

    curl -fsSL "$url" -o "$target_abs" || {
        rm -f "$target_abs"
        die "failed to download image"
    }

    [[ -n "$name" ]] || name="${filename%.*}"
    manifest_name="$(unique_manifest_name "$folder" "$name")"
    printf '%s\t%s\tfill\n' "$manifest_name" "$target_rel" >> "$MANIFEST_FILE"
    WALLPAPER_NAMES+=("$manifest_name")
    WALLPAPER_FILES+=("$target_rel")
    WALLPAPER_MODES+=("fill")
    WALLPAPER_TAGS+=("$tags")
    WALLPAPER_SOURCES+=("$source")
    WALLPAPER_AUTHORS+=("$author")
    WALLPAPER_LICENSES+=("$license")
    write_metadata
    printf 'downloaded %s -> %s\n' "$manifest_name" "$target_rel"
}

prompt_input() {
    local title="$1"
    local prompt="$2"
    local default_value="${3:-}"
    local answer
    local tty_device="/dev/tty"

    [[ -c "$tty_device" ]] || tty_device="/dev/stdout"
    stty sane 2>/dev/null || true
    printf '\033[?25h' > "$tty_device"
    clear > "$tty_device"
    printf '\n\033[1m%s\033[0m\n\n' "$title" > "$tty_device"
    if [[ -n "$default_value" ]]; then
        printf '%s [%s]: ' "$prompt" "$default_value" > "$tty_device"
    else
        printf '%s: ' "$prompt" > "$tty_device"
    fi

    IFS= read -r answer < "$tty_device"
    [[ -z "$answer" ]] && answer="$default_value"

    stty -icanon -echo 2>/dev/null || true
    printf '\033[?25l' > "$tty_device"
    printf '%s\n' "$answer"
}

prompt_message() {
    local title="$1"
    local message="$2"
    local tty_device="/dev/tty"

    [[ -c "$tty_device" ]] || tty_device="/dev/stdout"
    stty sane 2>/dev/null || true
    printf '\033[?25h' > "$tty_device"
    clear > "$tty_device"
    printf '\n\033[1m%s\033[0m\n\n%b\n' "$title" "$message" > "$tty_device"
    printf '\nPress Enter to continue...' > "$tty_device"
    IFS= read -r < "$tty_device"
    stty -icanon -echo 2>/dev/null || true
    printf '\033[?25l' > "$tty_device"
}

prompt_confirm() {
    local title="$1"
    local message="$2"
    local confirm_word="${3:-delete}"
    local answer

    answer="$(prompt_input "$title" "$message (type '$confirm_word' to confirm)")"
    [[ "$answer" == "$confirm_word" ]]
}

interactive_select() {
    local selected=0
    local has_preview=0
    local key
    local list_window=12
    local selected_name_after_action=""
    local COLOR_ACCENT='\033[38;5;110m'
    local COLOR_MARK='\033[38;5;179m'
    local COLOR_ACTIVE='\033[38;5;114m'
    local COLOR_DIM='\033[2m'
    local COLOR_RESET='\033[0m'
    local UI_LAST_FOLDER UI_SORT_MODE
    local -A MARKED_NAMES=()
    local -a VIEW_TYPES=() VIEW_LABELS=() VIEW_KEYS=() VIEW_WALLPAPER_INDEXES=()

    load_ui_state
    load_mark_names
    prune_mark_names

    [[ -n "$UI_LAST_FOLDER" ]] && is_folder_known "$UI_LAST_FOLDER" || UI_LAST_FOLDER=""

    printf '\033[?25l'
    stty -icanon -echo 2>/dev/null || true
    trap 'save_ui_state; save_mark_names; restore_terminal' EXIT

    has_chafa() {
        command -v chafa >/dev/null 2>&1
    }

    term_cols() {
        local cols
        cols="$(tput cols 2>/dev/null || printf '80')"
        if [[ "$cols" =~ ^[0-9]+$ ]] && (( cols > 0 )); then
            printf '%s\n' "$cols"
        else
            printf '80\n'
        fi
    }

    repeat_char() {
        local count="$1"
        local char="${2:-─}"
        local out=""
        while (( ${#out} < count )); do
            out+="$char"
        done
        printf '%.*s' "$count" "$out"
    }

    clamp_width() {
        local value="$1"
        local min="$2"
        local max="$3"
        (( value < min )) && value=$min
        (( value > max )) && value=$max
        printf '%s\n' "$value"
    }

    ellipsize() {
        local text="$1"
        local max_width="$2"
        if (( max_width <= 0 )); then
            printf '\n'
        elif (( ${#text} <= max_width )); then
            printf '%s\n' "$text"
        elif (( max_width <= 3 )); then
            printf '%.*s\n' "$max_width" "$text"
        else
            printf '%s...\n' "${text:0:max_width-3}"
        fi
    }

    render_header() {
        local title="$1"
        local subtitle="$2"
        local cols line_width
        cols="$(term_cols)"
        line_width="$(clamp_width "$((cols - 8))" 24 72)"
        printf '\033[1m%b%s%b\n' "$COLOR_ACCENT" "$title" "$COLOR_RESET"
        printf '%b%s%b\n' "$COLOR_DIM" "$(repeat_char "$line_width")" "$COLOR_RESET"
        [[ -n "$subtitle" ]] && printf '%b%s%b\n' "$COLOR_DIM" "$subtitle" "$COLOR_RESET"
        printf '\n'
    }

    render_footer() {
        local primary="$1"
        local secondary="$2"
        printf '\n%b%s%b\n' "$COLOR_DIM" "$primary" "$COLOR_RESET"
        [[ -n "$secondary" ]] && printf '%b%s%b\n' "$COLOR_DIM" "$secondary" "$COLOR_RESET"
    }

    render_help_line() {
        local key_label="$1"
        local description="$2"
        printf '  %b%-12s%b %s\n' "$COLOR_ACCENT" "$key_label" "$COLOR_RESET" "$description"
    }

    render_kbd() {
        local label="$1"
        printf '%b[%s]%b' "$COLOR_ACCENT" "$label" "$COLOR_RESET"
    }

    marked_count() {
        printf '%s\n' "${#MARKED_NAMES[@]}"
    }

    is_marked_name() {
        local name="$1"
        [[ -n "${MARKED_NAMES[$name]+x}" ]]
    }

    current_view_type() {
        printf '%s\n' "${VIEW_TYPES[$selected]}"
    }

    current_view_wallpaper_index() {
        printf '%s\n' "${VIEW_WALLPAPER_INDEXES[$selected]}"
    }

    current_view_key() {
        printf '%s\n' "${VIEW_KEYS[$selected]}"
    }

    current_folder_label() {
        local folder="${UI_LAST_FOLDER:-}"
        local crumb=""
        local part

        if [[ -z "$folder" ]]; then
            printf 'root\n'
            return 0
        fi

        crumb="root"
        IFS='/' read -r -a parts <<< "$folder"
        for part in "${parts[@]}"; do
            [[ -n "$part" ]] || continue
            crumb="$crumb / $part"
        done
        printf '%s\n' "$crumb"
    }

    folder_wallpaper_count() {
        local folder="${1:-}"
        local idx count=0 group
        for idx in "${!WALLPAPER_NAMES[@]}"; do
            group="$(wallpaper_group "$idx")"
            if [[ -z "$folder" ]]; then
                [[ "$group" == "." ]] && ((count += 1))
            else
                [[ "$group" == "$folder" || "$group" == "$folder/"* ]] && ((count += 1))
            fi
        done
        printf '%s\n' "$count"
    }

    folder_item_label() {
        local folder="${1:-}"
        local base="${folder##*/}"
        local count
        count="$(folder_wallpaper_count "$folder")"
        if [[ -z "$folder" || "$folder" == "." ]]; then
            printf 'root/ (%s)\n' "$count"
        else
            printf '%s/ (%s)\n' "$base" "$count"
        fi
    }

    select_view_by_key() {
        local type="$1"
        local key="$2"
        local i
        for i in "${!VIEW_TYPES[@]}"; do
            if [[ "${VIEW_TYPES[$i]}" == "$type" ]] && [[ "${VIEW_KEYS[$i]}" == "$key" ]]; then
                selected="$i"
                return 0
            fi
        done
        return 1
    }

    toggle_mark_selected() {
        local idx name
        [[ "$(current_view_type)" == "wallpaper" ]] || return 0
        idx="$(current_view_wallpaper_index)"
        name="${WALLPAPER_NAMES[$idx]}"
        if is_marked_name "$name"; then
            unset 'MARKED_NAMES[$name]'
        else
            MARKED_NAMES["$name"]=1
        fi
        save_mark_names
    }

    clear_marks() {
        MARKED_NAMES=()
        save_mark_names
    }

    selected_group() {
        local t
        t="$(current_view_type)"
        case "$t" in
            folder)
                current_view_key
                ;;
            parent)
                parent_folder "$UI_LAST_FOLDER"
                ;;
            wallpaper)
                wallpaper_group "$(current_view_wallpaper_index)"
                ;;
            *)
                printf '%s\n' "$UI_LAST_FOLDER"
                ;;
        esac
    }

    marked_or_selected_names() {
        local name
        if ((${#MARKED_NAMES[@]} > 0)); then
            for name in "${!MARKED_NAMES[@]}"; do
                printf '%s\n' "$name"
            done | sort
        elif [[ "$(current_view_type)" == "wallpaper" ]]; then
            printf '%s\n' "${WALLPAPER_NAMES[$(current_view_wallpaper_index)]}"
        fi
    }

    fuzzy_search_key() {
        local text="$1"
        printf '%s' "$text" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]'
    }

    fuzzy_jump() {
        local selection kind key idx group

        command -v fzf >/dev/null 2>&1 || {
            prompt_message "Fuzzy Jump" "fzf is not installed."
            return 0
        }

        selection="$(
            {
                printf 'root/\tfolder\t.\t%s\n' "$(fuzzy_search_key 'root')"
                while IFS= read -r group; do
                    [[ -n "$group" ]] || continue
                    printf '%s/\tfolder\t%s\t%s\n' "$group" "$group" "$(fuzzy_search_key "$group")"
                done < <(all_folder_paths)
                for idx in "${!WALLPAPER_NAMES[@]}"; do
                    printf '%s\twallpaper\t%s\t%s\n' \
                        "${WALLPAPER_NAMES[$idx]}" \
                        "${WALLPAPER_NAMES[$idx]}" \
                        "$(fuzzy_search_key "${WALLPAPER_NAMES[$idx]} ${WALLPAPER_FILES[$idx]}")"
                done
            } | fzf --delimiter=$'\t' --with-nth=1 --nth=1,4 --layout=reverse --height=80% --prompt='jump> '
        )" || return 0

        kind="$(printf '%s\n' "$selection" | cut -f2)"
        key="$(printf '%s\n' "$selection" | cut -f3)"

        if [[ "$kind" == "folder" ]]; then
            [[ "$key" == "." ]] && UI_LAST_FOLDER="" || UI_LAST_FOLDER="$key"
            selected=0
            save_ui_state
            return 0
        fi

        if [[ "$kind" == "wallpaper" ]]; then
            idx="$(resolve_index "$key" || true)"
            [[ -n "$idx" ]] || return 0
            group="$(wallpaper_group "$idx")"
            [[ "$group" == "." ]] && UI_LAST_FOLDER="" || UI_LAST_FOLDER="$group"
            save_ui_state
            build_view
            select_view_by_key "wallpaper" "$key" || true
        fi
    }

    prompt_select_folder() {
        local title="$1"
        local default_dir="${2:-}"
        local tty_device="/dev/tty"
        local key choice new_dir i
        local -a options=()
        local selected_option=0

        [[ -c "$tty_device" ]] || tty_device="/dev/stdout"

        load_folder_options() {
            options=("__root__")
            while IFS= read -r dir; do
                [[ -n "$dir" ]] && options+=("$dir")
            done < <(all_folder_paths)
            options+=("__create__")
        }

        option_label() {
            case "$1" in
                __root__) printf 'root /' ;;
                __create__) printf '+ create folder' ;;
                *) printf '%s/' "$1" ;;
            esac
        }

        load_folder_options
        if [[ -n "$default_dir" ]]; then
            for i in "${!options[@]}"; do
                if [[ "${options[$i]}" == "$default_dir" ]]; then
                    selected_option="$i"
                    break
                fi
            done
        fi

        stty sane 2>/dev/null || true
        printf '\033[?25h' > "$tty_device"

        while true; do
            clear > "$tty_device"
            printf '\n\033[1m%s\033[0m\n\n' "$title" > "$tty_device"
            printf '\033[2mChoose a target folder.\033[0m\n\n' > "$tty_device"

            for i in "${!options[@]}"; do
                if [[ "$i" -eq "$selected_option" ]]; then
                    printf '  \033[38;5;110m›\033[0m \033[1m%s\033[0m\n' "$(option_label "${options[$i]}")" > "$tty_device"
                else
                    printf '  \033[2m·\033[0m %s\n' "$(option_label "${options[$i]}")" > "$tty_device"
                fi
            done

            printf '\n\033[2mUse ↑↓ to choose • Enter to confirm • q to cancel\033[0m\n' > "$tty_device"
            IFS= read -r -s -n 1 key < "$tty_device"

            if [[ -z "$key" ]]; then
                choice="${options[$selected_option]}"
                if [[ "$choice" == "__create__" ]]; then
                    new_dir="$(prompt_input "Create Folder" "Folder path (relative to wallpapers)" "$default_dir")"
                    [[ -z "$new_dir" ]] && continue
                    new_dir="$(normalize_relative_dir "$new_dir")" || {
                        prompt_message "Choose Folder" "Invalid folder path."
                        continue
                    }
                    [[ -n "$new_dir" ]] || {
                        prompt_message "Choose Folder" "Use a subfolder name, not the wallpaper root."
                        continue
                    }
                    mkdir -p "$WALLPAPERS_DIR/$new_dir"
                    default_dir="$new_dir"
                    load_folder_options
                    for i in "${!options[@]}"; do
                        if [[ "${options[$i]}" == "$new_dir" ]]; then
                            selected_option="$i"
                            break
                        fi
                    done
                    continue
                elif [[ "$choice" == "__root__" ]]; then
                    stty -icanon -echo 2>/dev/null || true
                    printf '\033[?25l' > "$tty_device"
                    printf '\n'
                    return 0
                else
                    stty -icanon -echo 2>/dev/null || true
                    printf '\033[?25l' > "$tty_device"
                    printf '%s\n' "$choice"
                    return 0
                fi
            elif [[ "$key" == "q" ]] || [[ "$key" == $'\x7f' ]]; then
                stty -icanon -echo 2>/dev/null || true
                printf '\033[?25l' > "$tty_device"
                return 1
            elif [[ "$key" == $'\e' ]]; then
                IFS= read -r -s -n 1 -t 0.1 key < "$tty_device"
                if [[ "$key" == "[" ]]; then
                    IFS= read -r -s -n 1 -t 0.1 key < "$tty_device"
                    if [[ "$key" == "A" ]]; then
                        (( selected_option > 0 )) && ((selected_option -= 1))
                    elif [[ "$key" == "B" ]]; then
                        (( selected_option < ${#options[@]} - 1 )) && ((selected_option += 1))
                    fi
                fi
            fi
        done
    }

    build_view() {
        local idx group remainder child
        local -A folders_seen=()
        VIEW_TYPES=()
        VIEW_LABELS=()
        VIEW_KEYS=()
        VIEW_WALLPAPER_INDEXES=()

        [[ -n "$UI_LAST_FOLDER" ]] && {
            VIEW_TYPES+=("parent")
            VIEW_LABELS+=("$(folder_item_label "$(parent_folder "$UI_LAST_FOLDER")")")
            VIEW_KEYS+=("$(parent_folder "$UI_LAST_FOLDER")")
            VIEW_WALLPAPER_INDEXES+=("-1")
        }

        while IFS= read -r group; do
            if [[ -z "$UI_LAST_FOLDER" ]]; then
                child="${group%%/*}"
                [[ "$group" == "." ]] && continue
            else
                [[ "$group" == "$UI_LAST_FOLDER" ]] && continue
                [[ "$group" == "$UI_LAST_FOLDER/"* ]] || continue
                remainder="${group#"$UI_LAST_FOLDER"/}"
                child="${remainder%%/*}"
            fi
            [[ -n "$child" ]] || continue
            folders_seen["$child"]=1
        done < <(
            {
                for idx in "${!WALLPAPER_NAMES[@]}"; do
                    wallpaper_group "$idx"
                done
                all_folder_paths
            } | sort -u
        )

        for child in "${!folders_seen[@]}"; do
            VIEW_TYPES+=("folder")
            if [[ -n "$UI_LAST_FOLDER" ]]; then
                VIEW_KEYS+=("$UI_LAST_FOLDER/$child")
                VIEW_LABELS+=("$(folder_item_label "$UI_LAST_FOLDER/$child")")
            else
                VIEW_KEYS+=("$child")
                VIEW_LABELS+=("$(folder_item_label "$child")")
            fi
            VIEW_WALLPAPER_INDEXES+=("-1")
        done

        if ((${#folders_seen[@]} > 0)); then
            local i j
            for ((i = 0; i < ${#VIEW_TYPES[@]}; i++)); do :; done
        fi

        # Stable folder sort.
        if ((${#VIEW_TYPES[@]} > 1)); then
            local -a tmp_types=() tmp_labels=() tmp_keys=() tmp_indexes=()
            local line
            while IFS=$'\t' read -r line idx; do
                tmp_types+=("${VIEW_TYPES[$idx]}")
                tmp_labels+=("${VIEW_LABELS[$idx]}")
                tmp_keys+=("${VIEW_KEYS[$idx]}")
                tmp_indexes+=("${VIEW_WALLPAPER_INDEXES[$idx]}")
            done < <(for idx in "${!VIEW_TYPES[@]}"; do printf '%s\t%s\n' "${VIEW_LABELS[$idx]}" "$idx"; done | sort)
            VIEW_TYPES=("${tmp_types[@]}")
            VIEW_LABELS=("${tmp_labels[@]}")
            VIEW_KEYS=("${tmp_keys[@]}")
            VIEW_WALLPAPER_INDEXES=("${tmp_indexes[@]}")
        fi

        while IFS= read -r idx; do
            group="$(wallpaper_group "$idx")"
            if [[ "${UI_LAST_FOLDER:-.}" == "." || -z "$UI_LAST_FOLDER" ]]; then
                [[ "$group" == "." ]] || continue
            else
                [[ "$group" == "$UI_LAST_FOLDER" ]] || continue
            fi
            VIEW_TYPES+=("wallpaper")
            VIEW_LABELS+=("$(wallpaper_label "$idx")")
            VIEW_KEYS+=("${WALLPAPER_NAMES[$idx]}")
            VIEW_WALLPAPER_INDEXES+=("$idx")
        done < <(sorted_wallpaper_indices "$UI_SORT_MODE")

        (( selected < ${#VIEW_TYPES[@]} )) || selected=$((${#VIEW_TYPES[@]} - 1))
        (( selected >= 0 )) || selected=0
    }

    refresh_after_manifest_change() {
        read_manifest
        prune_mark_names
        save_mark_names
        [[ -n "$UI_LAST_FOLDER" ]] && is_folder_known "$UI_LAST_FOLDER" || UI_LAST_FOLDER=""
        build_view
        if [[ -n "$selected_name_after_action" ]]; then
            select_view_by_key "wallpaper" "$selected_name_after_action" || true
        fi
    }

    create_directory_interactive() {
        local target_dir
        target_dir="$(prompt_input "Create Folder" "Folder path (relative to wallpapers)" "$UI_LAST_FOLDER")"
        [[ -z "$target_dir" ]] && return 0
        target_dir="$(normalize_relative_dir "$target_dir")" || {
            prompt_message "Create Folder" "Invalid folder path."
            return 0
        }
        [[ -n "$target_dir" ]] || {
            prompt_message "Create Folder" "Use a subfolder name, not the wallpaper root."
            return 0
        }
        mkdir -p "$WALLPAPERS_DIR/$target_dir"
        UI_LAST_FOLDER="$target_dir"
        save_ui_state
        prompt_message "Create Folder" "Created: $target_dir/"
    }

    move_selected_interactive() {
        local target_dir names name idx label old_name old_rel target_rel active target_name moved_count=0
        names="$(marked_or_selected_names)"
        [[ -n "$names" ]] || return 0
        target_dir="$(prompt_select_folder "Move To Folder" "$UI_LAST_FOLDER")" || return 0
        target_dir="$(normalize_relative_dir "$target_dir")" || return 0

        while IFS= read -r name; do
            [[ -n "$name" ]] || continue
            idx="$(resolve_index "$name")" || continue
            label="$(wallpaper_label "$idx")"
            old_name="${WALLPAPER_NAMES[$idx]}"
            old_rel="${WALLPAPER_FILES[$idx]}"
            target_rel="${WALLPAPER_FILES[$idx]##*/}"
            [[ -n "$target_dir" ]] && target_rel="$target_dir/$target_rel"
            target_rel="$(unique_relative_path "$target_rel")"
            mkdir -p "$(dirname "$WALLPAPERS_DIR/$target_rel")"
            mv "$(wallpaper_path "$idx")" "$WALLPAPERS_DIR/$target_rel"

            active=0
            [[ "$(current_wallpaper_name)" == "$old_name" ]] && active=1
            WALLPAPER_FILES[$idx]="$target_rel"
            target_name="$(unique_manifest_name "$target_dir" "$label")"
            WALLPAPER_NAMES[$idx]="$target_name"
            unset 'MARKED_NAMES[$old_name]'
            MARKED_NAMES["$target_name"]=1
            selected_name_after_action="$target_name"
            cleanup_empty_parent_dirs "$old_rel"

            if (( active )); then
                ln -sfn "$WALLPAPERS_DIR/$target_rel" "$CURRENT_LINK"
                printf '%s\n' "$target_name" > "$STATE_FILE"
                start_wallpaper "${WALLPAPER_MODES[$idx]}"
            fi
            ((moved_count += 1))
        done <<< "$names"

        write_manifest
        clear_marks
        UI_LAST_FOLDER="$target_dir"
        save_ui_state
        prompt_message "Move Wallpaper" "Moved $moved_count wallpaper(s) to:\n${target_dir:-root}/"
    }

    rename_selected_interactive() {
        local idx old_name old_rel current_group current_label current_base
        local new_group new_label new_file target_rel target_name active=0

        [[ "$(current_view_type)" == "wallpaper" ]] || return 0
        idx="$(current_view_wallpaper_index)"
        old_name="${WALLPAPER_NAMES[$idx]}"
        old_rel="${WALLPAPER_FILES[$idx]}"
        current_group="$(wallpaper_group "$idx")"
        [[ "$current_group" == "." ]] && current_group=""
        current_label="$(wallpaper_label "$idx")"
        current_base="$(basename "$old_rel")"

        new_group="$(prompt_select_folder "Choose Folder For Rename" "$current_group")" || return 0
        new_group="$(normalize_relative_dir "$new_group")" || return 0
        new_label="$(prompt_input "Rename Wallpaper" "Wallpaper name" "$current_label")"
        [[ -n "$new_label" ]] || return 0
        new_file="$(prompt_input "Rename Wallpaper" "File name" "$current_base")"
        [[ -n "$new_file" ]] || return 0
        [[ "$new_file" == */* ]] && {
            prompt_message "Rename Wallpaper" "File name cannot contain '/'."
            return 0
        }

        target_rel="$new_file"
        [[ -n "$new_group" ]] && target_rel="$new_group/$new_file"
        if [[ "$target_rel" != "$old_rel" ]]; then
            target_rel="$(unique_relative_path "$target_rel")"
            mkdir -p "$(dirname "$WALLPAPERS_DIR/$target_rel")"
            mv "$(wallpaper_path "$idx")" "$WALLPAPERS_DIR/$target_rel"
            cleanup_empty_parent_dirs "$old_rel"
        fi

        [[ "$(current_wallpaper_name)" == "$old_name" ]] && active=1
        WALLPAPER_FILES[$idx]="$target_rel"
        target_name="$(unique_manifest_name "$new_group" "$new_label")"
        WALLPAPER_NAMES[$idx]="$target_name"
        write_manifest

        if (( active )); then
            ln -sfn "$WALLPAPERS_DIR/$target_rel" "$CURRENT_LINK"
            printf '%s\n' "$target_name" > "$STATE_FILE"
            start_wallpaper "${WALLPAPER_MODES[$idx]}"
        fi

        if is_marked_name "$old_name"; then
            unset 'MARKED_NAMES[$old_name]'
            MARKED_NAMES["$target_name"]=1
            save_mark_names
        fi

        selected_name_after_action="$target_name"
        UI_LAST_FOLDER="$new_group"
        save_ui_state
        prompt_message "Rename Wallpaper" "Updated:\n$target_name\n-> $target_rel"
    }

    delete_selected_interactive() {
        local names name idx old_rel active=0 deleted=0
        names="$(marked_or_selected_names)"
        [[ -n "$names" ]] || {
            if [[ "$(current_view_type)" == "folder" ]]; then
                local folder
                folder="$(current_view_key)"
                if [[ -d "$WALLPAPERS_DIR/$folder" ]] && rmdir "$WALLPAPERS_DIR/$folder" 2>/dev/null; then
                    UI_LAST_FOLDER="$(parent_folder "$folder")"
                    save_ui_state
                    prompt_message "Delete Folder" "Deleted empty folder:\n$folder/"
                else
                    prompt_message "Delete Folder" "Folder is not empty:\n$folder/"
                fi
            fi
            return 0
        }

        prompt_confirm "Delete Wallpaper" "Delete selected wallpaper(s) and prune empty folders?" "delete" || return 0

        while IFS= read -r name; do
            [[ -n "$name" ]] || continue
            idx="$(resolve_index "$name")" || continue
            old_rel="${WALLPAPER_FILES[$idx]}"
            [[ "$(current_wallpaper_name)" == "$name" ]] && active=1
            rm -f "$(wallpaper_path "$idx")"
            unset 'WALLPAPER_NAMES[$idx]'
            unset 'WALLPAPER_FILES[$idx]'
            unset 'WALLPAPER_MODES[$idx]'
            unset 'MARKED_NAMES[$name]'
            cleanup_empty_parent_dirs "$old_rel"
            ((deleted += 1))
        done <<< "$names"

        WALLPAPER_NAMES=("${WALLPAPER_NAMES[@]}")
        WALLPAPER_FILES=("${WALLPAPER_FILES[@]}")
        WALLPAPER_MODES=("${WALLPAPER_MODES[@]}")
        write_manifest
        save_mark_names
        if (( active )); then
            rm -f "$CURRENT_LINK" "$STATE_FILE"
        fi
        prompt_message "Delete Wallpaper" "Deleted $deleted wallpaper(s)."
    }

    download_wallpaper_interactive() {
        local url ext target_dir filename target_rel target_abs name manifest_name tags source author license
        url="$(prompt_input "Download Wallpaper" "Image URL")"
        [[ -n "$url" ]] || return 0
        ext="$(image_extension_from_url "$url" 2>/dev/null || true)"
        if [[ -z "$ext" ]]; then
            local mime
            mime="$(curl -fsSLI "$url" | awk -F': ' 'BEGIN{IGNORECASE=1} /^content-type:/ {print $2}' | tail -n1 | tr -d '\r' | cut -d';' -f1)"
            case "$mime" in
                image/jpeg) ext="jpg" ;;
                image/png) ext="png" ;;
                image/webp) ext="webp" ;;
            esac
        fi
        [[ -n "$ext" ]] || {
            prompt_message "Download Wallpaper" "Could not determine image type from the URL."
            return 0
        }

        target_dir="$(prompt_select_folder "Choose Download Folder" "$UI_LAST_FOLDER")" || return 0
        target_dir="$(normalize_relative_dir "$target_dir")" || return 0

        filename="$(download_filename_from_url "$url" "$ext")"
        target_rel="$filename"
        [[ -n "$target_dir" ]] && target_rel="$target_dir/$filename"
        target_rel="$(unique_relative_path "$target_rel")"
        target_abs="$WALLPAPERS_DIR/$target_rel"
        mkdir -p "$(dirname "$target_abs")"

        if ! curl -fsSL "$url" -o "$target_abs"; then
            rm -f "$target_abs"
            prompt_message "Download Wallpaper" "Failed to download image."
            return 0
        fi

        name="$(prompt_input "Download Wallpaper" "Wallpaper name" "${filename%.*}")"
        [[ -n "$name" ]] || name="${filename%.*}"
        tags="$(prompt_input "Download Wallpaper" "Tags (comma separated)" "")"
        tags="$(normalize_tags "$tags")"
        source="$(prompt_input "Download Wallpaper" "Source URL" "$url")"
        author="$(prompt_input "Download Wallpaper" "Author" "")"
        license="$(prompt_input "Download Wallpaper" "License" "")"
        manifest_name="$(unique_manifest_name "$target_dir" "$name")"
        printf '%s\t%s\tfill\n' "$manifest_name" "$target_rel" >> "$MANIFEST_FILE"
        WALLPAPER_NAMES+=("$manifest_name")
        WALLPAPER_FILES+=("$target_rel")
        WALLPAPER_MODES+=("fill")
        WALLPAPER_TAGS+=("$tags")
        WALLPAPER_SOURCES+=("$source")
        WALLPAPER_AUTHORS+=("$author")
        WALLPAPER_LICENSES+=("$license")
        write_metadata
        selected_name_after_action="$manifest_name"
        UI_LAST_FOLDER="$target_dir"
        save_ui_state
        prompt_message "Download Wallpaper" "Downloaded to:\n$target_rel\n\nAdded as:\n$manifest_name"
    }

    folder_preview_lines() {
        local folder="$1"
        local current_name="$2"
        local idx shown=0
        while IFS= read -r idx; do
            [[ "$(wallpaper_group "$idx")" == "${folder:-.}" ]] || continue
            if [[ "${WALLPAPER_NAMES[$idx]}" == "$current_name" ]]; then
                printf '  %b› %s%b\n' "$COLOR_ACCENT" "$(wallpaper_label "$idx")" "$COLOR_RESET"
            elif is_marked_name "${WALLPAPER_NAMES[$idx]}"; then
                printf '  %b* %s%b\n' "$COLOR_MARK" "$(wallpaper_label "$idx")" "$COLOR_RESET"
            else
                printf '  · %s\n' "$(wallpaper_label "$idx")"
            fi
            ((shown += 1))
            (( shown >= 6 )) && break
        done < <(sorted_wallpaper_indices "$UI_SORT_MODE")
        (( shown > 0 )) || printf '  %b(empty)%b\n' "$COLOR_DIM" "$COLOR_RESET"
    }

    render_list() {
        local start end total cols width marker badge active
        local i type key label idx

        build_view
        total="${#VIEW_TYPES[@]}"
        cols="$(term_cols)"
        width="$(clamp_width "$((cols - 34))" 16 52)"
        active="$(current_wallpaper_name)"

        printf '\033[H\033[2J'
        render_header \
            "Wallpaper Picker" \
            "$(current_folder_label) • sort: $UI_SORT_MODE • $(marked_count) marked • current: ${active:-none}"

        start=$((selected - list_window / 2))
        (( start < 0 )) && start=0
        end=$((start + list_window - 1))
        if (( end >= total )); then
            end=$((total - 1))
            start=$((end - list_window + 1))
            (( start < 0 )) && start=0
        fi

        if (( start > 0 )); then
            printf '  %b↑ %d more above%b\n\n' "$COLOR_DIM" "$start" "$COLOR_RESET"
        fi

        for ((i = start; i <= end; i++)); do
            type="${VIEW_TYPES[$i]}"
            key="${VIEW_KEYS[$i]}"
            label="${VIEW_LABELS[$i]}"
            badge=""

            if [[ "$type" == "wallpaper" ]]; then
                idx="${VIEW_WALLPAPER_INDEXES[$i]}"
                [[ "${WALLPAPER_NAMES[$idx]}" == "$active" ]] && badge="  ${COLOR_ACTIVE}current${COLOR_RESET}"
                if is_marked_name "${WALLPAPER_NAMES[$idx]}"; then
                    label="* $label"
                else
                    label="  $label"
                fi
            elif [[ "$type" == "folder" ]]; then
                label="$label"
            elif [[ "$type" == "parent" ]]; then
                label="../"
            fi

            label="$(ellipsize "$label" "$width")"
            if (( i == selected )); then
                marker="${COLOR_ACCENT}›${COLOR_RESET}"
                printf ' %b \033[1m%-*s\033[0m%b\n' "$marker" "$width" "$label" "$badge"
            else
                marker="${COLOR_DIM}·${COLOR_RESET}"
                printf ' %b %-*s%b\n' "$marker" "$width" "$label" "$badge"
            fi
        done

        if (( end < total - 1 )); then
            printf '\n  %b↓ %d more below%b\n' "$COLOR_DIM" "$((total - end - 1))" "$COLOR_RESET"
        fi

        render_footer \
            "$(render_kbd '↑↓') move  $(render_kbd 'Enter') open/apply  $(render_kbd 'Space') mark  $(render_kbd 'p') preview  $(render_kbd '/') jump  $(render_kbd 'm') move  $(render_kbd 's') sort" \
            "$(render_kbd 'n') rename  $(render_kbd 'd') folder  $(render_kbd '+') add  $(render_kbd '!') delete  $(render_kbd 'x') clear  $(render_kbd 'r') random  $(render_kbd 'q') quit"
    }

    render_help() {
        printf '\033[H\033[2J'
        render_header "Wallpaper Help" "Interactive controls"
        render_help_line "↑ / ↓" "Move through folders and wallpapers"
        render_help_line "Enter" "Enter folder or apply wallpaper"
        render_help_line "Space" "Mark or unmark the selected wallpaper"
        render_help_line "p" "Toggle preview"
        render_help_line "/" "Fuzzy jump via fzf across folders and files"
        render_help_line "m" "Move marked wallpapers, or the selected one"
        render_help_line "n" "Rename the selected wallpaper"
        render_help_line "+" "Download from a direct web image URL"
        render_help_line "d" "Create a folder"
        render_help_line "!" "Delete marked wallpapers, or selected folder if empty"
        render_help_line "s" "Cycle sort: name -> folder -> recent"
        render_help_line "x" "Clear all marks"
        render_help_line "r" "Random wallpaper / rotation"
        render_help_line "o" "Open the wallpapers directory"
        render_help_line "?" "Open this help screen"
        render_help_line "q" "Exit"
        render_footer "Any key returns to the picker" ""
    }

render_preview() {
        local type idx path folder dims size modified mime count folders files tags source author license
        type="$(current_view_type)"

        printf '\033[H\033[2J'
        if [[ "$type" == "wallpaper" ]]; then
            idx="$(current_view_wallpaper_index)"
            path="$(wallpaper_path "$idx")"
            folder="$(wallpaper_group "$idx")"
            [[ "$folder" == "." ]] && folder="root"
            dims="$(image_dimensions "$path")"
            size="$(file_size_human "$path")"
            modified="$(file_mtime_human "$path")"
            mime="$(mime_type "$path")"
            tags="${WALLPAPER_TAGS[$idx]:-none}"
            source="${WALLPAPER_SOURCES[$idx]:-none}"
            author="${WALLPAPER_AUTHORS[$idx]:-none}"
            license="${WALLPAPER_LICENSES[$idx]:-none}"

            render_header \
                "Preview" \
                "${WALLPAPER_NAMES[$idx]} • folder: $folder • mode: ${WALLPAPER_MODES[$idx]}"

            if [[ -f "$path" ]]; then
                if has_chafa; then
                    chafa -s 64x16 "$path" 2>/dev/null || printf '%bPreview failed.%b\n' "$COLOR_DIM" "$COLOR_RESET"
                else
                    printf '%bInstall chafa for inline previews.%b\n' "$COLOR_DIM" "$COLOR_RESET"
                fi
                printf '\n%bPath:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "${WALLPAPER_FILES[$idx]}"
                printf '%bType:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "$mime"
                printf '%bSize:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "$size"
                printf '%bDimensions:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "$dims"
                printf '%bModified:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "$modified"
                printf '%bMarked:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "$(is_marked_name "${WALLPAPER_NAMES[$idx]}" && printf 'yes' || printf 'no')"
                printf '%bTags:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "${tags:-none}"
                printf '%bSource:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "${source:-none}"
                printf '%bAuthor:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "${author:-none}"
                printf '%bLicense:%b %s\n' "$COLOR_DIM" "$COLOR_RESET" "${license:-none}"
            else
                printf '\n\033[31mFile not found: %s\033[0m\n' "$path"
            fi

            printf '\n%bFolder preview:%b %s/\n' "$COLOR_DIM" "$COLOR_RESET" "$folder"
            folder_preview_lines "$(wallpaper_group "$idx")" "${WALLPAPER_NAMES[$idx]}"
        else
            folder="$UI_LAST_FOLDER"
            [[ "$type" == "folder" ]] && folder="$(current_view_key)"
            [[ "$type" == "parent" ]] && folder="$(parent_folder "$UI_LAST_FOLDER")"
            [[ -n "$folder" ]] || folder="."
            folders="$(find "$WALLPAPERS_DIR/${folder#.}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')"
            files=0
            while IFS= read -r idx; do
                [[ "$(wallpaper_group "$idx")" == "$folder" ]] && ((files += 1))
            done < <(printf '%s\n' "${!WALLPAPER_NAMES[@]}")
            render_header \
                "Folder Preview" \
                "$( [[ "$folder" == "." ]] && printf 'root' || printf '%s' "$folder" ) • $folders folder(s) • $files wallpaper(s)"
            folder_preview_lines "$folder" ""
        fi

        render_footer \
            "$(render_kbd '↑↓') move  $(render_kbd 'Enter') open/apply  $(render_kbd 'p') back  $(render_kbd '/') jump  $(render_kbd 'Space') mark  $(render_kbd 'm') move  $(render_kbd 's') sort" \
            "$(render_kbd '!') delete  $(render_kbd 'd') folder  $(render_kbd '+') add  $(render_kbd 'x') clear"
    }

    mode="list"
    build_view
    if [[ -n "$(current_wallpaper_name)" ]]; then
        select_view_by_key "wallpaper" "$(current_wallpaper_name)" || true
    fi
    render_list

    while IFS= read -r -s -n 1 key; do
        case "$key" in
            "")
                if [[ "$mode" == "help" ]]; then
                    mode="list"
                else
                    if [[ "$(current_view_type)" == "folder" ]]; then
                        UI_LAST_FOLDER="$(current_view_key)"
                        selected=0
                        save_ui_state
                    elif [[ "$(current_view_type)" == "parent" ]]; then
                        UI_LAST_FOLDER="$(current_view_key)"
                        selected=0
                        save_ui_state
                    elif [[ "$(current_view_type)" == "wallpaper" ]]; then
                        restore_terminal
                        clear
                        set_wallpaper "${WALLPAPER_NAMES[$(current_view_wallpaper_index)]}"
                        save_ui_state
                        save_mark_names
                        trap - EXIT
                        return 0
                    fi
                fi
                ;;
            q|$'\x7f')
                restore_terminal
                clear
                save_ui_state
                save_mark_names
                trap - EXIT
                return 0
                ;;
            '?')
                mode="help"
                ;;
            o|O)
                open_wallpapers_dir
                ;;
            ' ')
                toggle_mark_selected
                ;;
            '+')
                mode="list"
                download_wallpaper_interactive
                refresh_after_manifest_change
                ;;
            d|D)
                mode="list"
                create_directory_interactive
                refresh_after_manifest_change
                ;;
            m|M)
                mode="list"
                move_selected_interactive
                refresh_after_manifest_change
                ;;
            n|N)
                mode="list"
                rename_selected_interactive
                refresh_after_manifest_change
                ;;
            x|X)
                clear_marks
                ;;
            r|R)
                mode="list"
                random_wallpaper_interactive
                read_manifest
                build_view
                ;;
            p|P)
                if [[ "$mode" == "preview" ]]; then
                    mode="list"
                else
                    mode="preview"
                fi
                ;;
            /)
                mode="list"
                fuzzy_jump
                build_view
                ;;
            s|S)
                cycle_sort_mode
                save_ui_state
                build_view
                selected=0
                ;;
            '!')
                mode="list"
                delete_selected_interactive
                refresh_after_manifest_change
                ;;
            $'\e')
                IFS= read -r -s -n 1 -t 0.1 key
                if [[ "$key" == "[" ]]; then
                    IFS= read -r -s -n 1 -t 0.1 key
                    if [[ "$key" == "A" ]]; then
                        if ((${#VIEW_TYPES[@]} > 0)); then
                            selected=$(( (selected - 1 + ${#VIEW_TYPES[@]}) % ${#VIEW_TYPES[@]} ))
                        fi
                    elif [[ "$key" == "B" ]]; then
                        if ((${#VIEW_TYPES[@]} > 0)); then
                            selected=$(( (selected + 1) % ${#VIEW_TYPES[@]} ))
                        fi
                    fi
                fi
                ;;
        esac

        if [[ "$mode" == "help" ]]; then
            render_help
        elif [[ "$mode" == "preview" ]]; then
            build_view
            render_preview
        else
            render_list
        fi
    done
}

edit_manifest() {
    "${EDITOR:-nvim}" "$MANIFEST_FILE"
}

usage() {
    printf '\n'
    printf '\033[1mUsage:\033[0m wallpaper [command] [options]\n\n'
    printf '\033[1mCommands:\033[0m\n'
    printf '  \033[36minteractive\033[0m              Open the interactive wallpaper manager\n'
    printf '  \033[36mset\033[0m <name>              Set wallpaper by manifest name\n'
    printf '  \033[36mlist\033[0m [--sort mode] [--tag tag] [--query text] [--folder dir]\n'
    printf '  \033[36mnext\033[0m                    Switch to next wallpaper\n'
    printf '  \033[36mprev\033[0m                    Switch to previous wallpaper\n'
    printf '  \033[36mrandom\033[0m                  Set a random wallpaper\n'
    printf '  \033[36mrotate\033[0m [seconds] [--folder dir]  Start random rotation in the background\n'
    printf '  \033[36mstatus\033[0m                  Show random rotation status\n'
    printf '  \033[36mstop\033[0m                    Stop random rotation\n'
    printf '  \033[36mopen\033[0m                    Open wallpapers directory\n'
    printf '  \033[36medit\033[0m                    Edit manifest in $EDITOR\n'
    printf '  \033[36mmkdir\033[0m <dir>            Create a wallpaper folder\n'
    printf '  \033[36mmove\033[0m <dir> <names...>   Move one or more wallpapers to a folder\n'
    printf '  \033[36mrename\033[0m <old> <new> [--file name] [--folder dir]\n'
    printf '  \033[36mdelete\033[0m <names...>       Delete one or more wallpapers and prune empty folders\n'
    printf '  \033[36mdownload\033[0m <url> [--folder dir] [--name label]\n'
    printf '  \033[36madd\033[0m <url> ...           Alias for `download`\n'
    printf '  \033[36mimport\033[0m <path-or-url> ...  Import local files, folders, or URLs\n'
    printf '  \033[36mmeta\033[0m <name> ...          Edit tags/source/author/license metadata\n'
    printf '  \033[36mhelp\033[0m                    Show this help\n\n'
    printf '\033[1mInteractive Keys:\033[0m\n'
    printf '  \033[36mEnter\033[0m   Enter folder or apply wallpaper\n'
    printf '  \033[36mSpace\033[0m   Mark wallpaper for bulk move/delete\n'
    printf '  \033[36mp\033[0m       Preview selected wallpaper or folder metadata\n'
    printf '  \033[36mm\033[0m       Move marked wallpapers, or the selected one\n'
    printf '  \033[36m!\033[0m       Delete marked wallpapers, or empty selected folder\n'
    printf '  \033[36ms\033[0m       Cycle sort mode\n'
    printf '  \033[36m+\033[0m       Download wallpaper from a web image URL\n'
    printf '  \033[36md\033[0m       Create folder\n'
    printf '  \033[36mn\033[0m       Rename wallpaper\n'
    printf '  \033[36mx\033[0m       Clear marks\n'
    printf '  \033[36mq\033[0m       Exit\n\n'
    printf '\033[1mExamples:\033[0m\n'
    printf '  \033[32mwallpaper list --sort recent\033[0m\n'
    printf '  \033[32mwallpaper mkdir anime/fuji\033[0m\n'
    printf '  \033[32mwallpaper move archive/cozy alpha beta\033[0m\n'
    printf '  \033[32mwallpaper rename alpha evening-fuji --file evening-fuji.png --folder archive/cozy\033[0m\n'
    printf '  \033[32mwallpaper delete archive/cozy/alpha\033[0m\n'
    printf '  \033[32mwallpaper download https://example.com/wall.png --folder anime --name sunset\033[0m\n\n'
    printf '  \033[32mwallpaper rotate 300 --folder fuji\033[0m\n'
    printf '  \033[32mwallpaper status\033[0m\n'
    printf '  \033[32mwallpaper stop\033[0m\n\n'
}

main() {
    read_manifest
    ensure_user_data_dir

    local cmd="${1:-interactive}"
    shift || true

    case "$cmd" in
        interactive|"")
            interactive_select
            ;;
        set|--set|-s)
            if [[ "$cmd" == "-s" && $# -eq 0 ]]; then
                stop_rotation
                return
            fi
            [[ $# -ge 1 ]] || die "set needs wallpaper name"
            set_wallpaper "$1"
            ;;
        list|--list|-l)
            local sort_mode="$SORT_MODE_DEFAULT"
            local folder=""
            local tag=""
            local query=""
            while (($#)); do
                case "$1" in
                    --sort)
                        sort_mode="${2:-}"
                        shift 2
                        ;;
                    --folder)
                        folder="${2:-}"
                        shift 2
                        ;;
                    --tag)
                        tag="$(normalize_tags "${2:-}")"
                        shift 2
                        ;;
                    --query)
                        query="${2:-}"
                        shift 2
                        ;;
                    *)
                        die "unknown list option: $1"
                        ;;
                esac
            done
            list_wallpapers "$sort_mode" "$folder" "$tag" "$query"
            ;;
        next|--next|-n)
            next_wallpaper
            ;;
        prev|--prev|-p)
            prev_wallpaper
            ;;
        random|--random|-r)
            random_wallpaper
            ;;
        status|--status)
            rotation_status
            ;;
        stop|--stop)
            stop_rotation
            ;;
        __rotate-loop)
            local duration="${1:-60}"
            shift || true
            [[ "$duration" =~ ^[0-9]+$ ]] || die "duration must be a number"
            [[ $# -gt 0 ]] || die "no wallpapers available"
            random_rotation_loop "$duration" "$@"
            ;;
        rotate|--rotate)
            local duration="${1:-60}"
            local folder=""
            local scope="all"
            while (($#)); do
                case "$1" in
                    --duration)
                        duration="${2:-60}"
                        shift 2
                        ;;
                    --folder)
                        folder="${2:-}"
                        shift 2
                        ;;
                    *)
                        shift
                        ;;
                esac
            done
            [[ "$duration" =~ ^[0-9]+$ ]] || die "duration must be a number"
            (( duration > 0 )) || die "duration must be greater than 0"

            local -a pool=()
            if [[ -n "$folder" ]]; then
                folder="$(normalize_relative_dir "$folder")" || die "invalid folder"
                scope="${folder:-root}"
                local name
                while IFS= read -r name; do
                    [[ -n "$name" ]] && pool+=("$name")
                done < <(wallpaper_names_for_folder "$folder")
            else
                pool=("${WALLPAPER_NAMES[@]}")
            fi
            [[ ${#pool[@]} -gt 0 ]] || die "no wallpapers available"

            start_rotation_daemon "$duration" "$scope" "${pool[@]}"
            ;;
        open|--open|-o)
            open_wallpapers_dir
            ;;
        edit|--edit|-e)
            edit_manifest
            ;;
        mkdir)
            [[ $# -ge 1 ]] || die "mkdir needs a folder path"
            mkdir_wallpaper_dir "$1"
            ;;
        move)
            [[ $# -ge 2 ]] || die "move needs a target folder and at least one wallpaper name"
            local target_dir="$1"
            shift
            move_wallpaper_items "$target_dir" "$@"
            ;;
        rename)
            [[ $# -ge 2 ]] || die "rename needs old and new wallpaper names"
            rename_wallpaper_item "$@"
            ;;
        delete|rm|remove)
            [[ $# -ge 1 ]] || die "delete needs at least one wallpaper name"
            delete_wallpaper_items "$@"
            ;;
        download|add|--add|-a)
            [[ $# -ge 1 ]] || die "download needs a URL"
            download_wallpaper_noninteractive "$@"
            ;;
        import)
            [[ $# -ge 1 ]] || die "import needs a path or URL"
            import_wallpaper_target "$@"
            ;;
        meta)
            [[ $# -ge 1 ]] || die "meta needs at least one wallpaper name"
            # TODO: add an interactive editor for metadata.
            while (($#)); do
                local idx name tags source author license
                name="$1"
                idx="$(resolve_index "$name")" || die "unknown wallpaper: $name"
                tags="$(prompt_input "Edit Metadata" "Tags (comma separated)" "${WALLPAPER_TAGS[$idx]}")"
                source="$(prompt_input "Edit Metadata" "Source" "${WALLPAPER_SOURCES[$idx]}")"
                author="$(prompt_input "Edit Metadata" "Author" "${WALLPAPER_AUTHORS[$idx]}")"
                license="$(prompt_input "Edit Metadata" "License" "${WALLPAPER_LICENSES[$idx]}")"
                update_wallpaper_metadata "$idx" "$(normalize_tags "$tags")" "$source" "$author" "$license"
                shift
            done
            write_metadata
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            die "unknown command: $cmd. Use 'wallpaper help' for usage"
            ;;
    esac
}

main "$@"
