#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

const C = {
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  cyan: '\x1b[36m',
  gray: '\x1b[90m'
};

const log = (msg, c = 'reset') => console.log(`${C[c]}${msg}${C.reset}`);

const PATTERNS = {
  common: ['node_modules', 'dist', 'build', 'out', 'tmp', 'temp', '.temp', 'coverage', '.nyc_output', '.turbo', '.cache'],
  next: ['.next'],
  vite: ['.vite'],
  svelte: ['.svelte-kit'],
  solid: ['.solid'],
  qwik: ['.qwik'],
  tauri: ['src-tauri/target', 'src-tauri/gen'],
  electron: ['src-electron/dist', 'release', 'app/dist'],
  astro: ['.astro'],
  nuxt: ['.nuxt', '.output'],
  locks: ['bun.lock', 'bun.lockb', 'package-lock.json', 'pnpm-lock.yaml', 'yarn.lock', 'deno.lock']
};

const FLAGS = {
  '--help': 'help',
  '-h': 'help',
  '--interactive': 'interactive',
  '-i': 'interactive',
  '--dry': 'dry',
  '-d': 'dry',
  '--verbose': 'verbose',
  '-vv': 'verbose',
  '--nolock': 'nolock',
  '-nl': 'nolock',
  '--reinstall': 'reinstall',
  '-r': 'reinstall',
  '--reinstall:pnpm': 'reinstall',
  '-rp': 'reinstall',
  '--reinstall:npm': 'reinstall',
  '-rn': 'reinstall',
  '--reinstall:yarn': 'reinstall',
  '-ry': 'reinstall',
  '--next': 'next',
  '-n': 'next',
  '--vite': 'vite',
  '--svelte': 'svelte',
  '--solid': 'solid',
  '--qwik': 'qwik',
  '--tauri': 'tauri',
  '--electron': 'electron',
  '--astro': 'astro',
  '--nuxt': 'nuxt',
  '--node': 'node',
  '-N': 'node',
  '--size': 'size',
  '-s': 'size'
};

function parseArgs() {
  const args = process.argv.slice(2);
  const opt = { help: false, interactive: false, dry: false, verbose: false, nolock: false, reinstall: null, frameworks: [], node: false, size: false, target: null };
  
  let i = 0;
  while (i < args.length) {
    const arg = args[i];
    if (arg === '--') {
      opt.target = args.slice(i + 1).join(' ');
      break;
    }
    const flag = FLAGS[arg];
    if (flag) {
      if (['help', 'interactive', 'dry', 'verbose', 'nolock', 'node', 'size'].includes(flag)) opt[flag] = true;
      else if (flag === 'reinstall') opt.reinstall = 'bun';
      else if (flag.startsWith('reinstall')) opt.reinstall = flag.split(':')[1];
      else if (!['frameworks'].includes(flag)) opt.frameworks.push(flag);
    } else if (!arg.startsWith('-')) {
      opt.target = arg;
    }
    i++;
  }
  return opt;
}

function getPaths(opt) {
  if (opt.nolock) return PATTERNS.locks;
  if (opt.frameworks.length > 0) {
    return [...PATTERNS.common, ...opt.frameworks.flatMap(f => PATTERNS[f] || []), ...PATTERNS.locks];
  }
  return Object.values(PATTERNS).flat();
}

function formatBytes(b) {
  if (!b) return '0 B';
  const k = 1024, s = ['B', 'KB', 'MB', 'GB', 'TB'];
  const idx = Math.min(Math.floor(Math.log(b) / Math.log(k)), s.length - 1);
  return parseFloat((b / Math.pow(k, idx)).toFixed(2)) + ' ' + s[idx];
}

function findNodeModules(dir, maxDepth = 10) {
  const results = [];
  function walk(d, depth = 0) {
    if (depth > maxDepth) return;
    try {
      const entries = fs.readdirSync(d);
      for (const entry of entries) {
        if (entry === 'node_modules') {
          results.push(path.join(d, entry));
        } else {
          const full = path.join(d, entry);
          try {
            if (fs.statSync(full).isDirectory()) walk(full, depth + 1);
          } catch {}
        }
      }
    } catch {}
  }
  walk(dir);
  return results;
}

async function getDirSize(p) {
  try {
    const out = execSync(`du -sb "$p" 2>/dev/null | cut -f1`, { shell: '/bin/bash', encoding: 'utf8' });
    return parseInt(out.trim()) || 0;
  } catch { return 0; }
}

async function calcNodeSizes(targetDir) {
  const base = targetDir || process.cwd();
  log('\n🔍 Scanning for node_modules in: ' + base + '\n', 'cyan');
  
  const dirs = findNodeModules(base);
  if (!dirs.length) {
    log('No node_modules found.', 'yellow');
    return;
  }
  
  log('Found ' + dirs.length + ' node_modules directories:\n', 'green');
  
  const sizes = await Promise.all(dirs.map(async d => ({
    path: d,
    size: await getDirSize(d)
  })));
  
  sizes.sort((a, b) => b.size - a.size);
  
  let total = 0;
  for (const s of sizes) {
    const rel = path.relative(base, s.path);
    log('  ' + formatBytes(s.size).padStart(10) + '  ' + rel, 'gray');
    total += s.size;
  }
  
  log('\n' + '='.repeat(50), 'gray');
  log('Total: ' + formatBytes(total), 'green');
  log('='.repeat(50) + '\n', 'gray');
}

async function removeNodeModules(targetDir, opt) {
  const base = targetDir || process.cwd();
  log('\n🧹 Removing node_modules in: ' + base + '\n', 'cyan');
  
  const dirs = findNodeModules(base);
  if (!dirs.length) {
    log('No node_modules found.', 'yellow');
    return;
  }
  
  if (opt.dry) {
    for (const d of dirs) {
      const size = await getDirSize(d);
      log('[DRY] Would remove: ' + path.relative(base, d) + ' (' + formatBytes(size) + ')', 'yellow');
    }
    return;
  }
  
  const sizes = await Promise.all(dirs.map(d => getDirSize(d)));
  const freed = sizes.reduce((a, b) => a + b, 0);
  
  await Promise.all(dirs.map(d => {
    fs.rmSync(d, { recursive: true, force: true });
    log('✓ Removed: ' + path.relative(base, d), 'green');
  }));
  
  log('\n✓ Freed: ' + formatBytes(freed) + '\n', 'green');
}

async function removePath(p, opt, cwd) {
  const full = path.join(cwd, p);
  const exists = fs.existsSync(full);
  if (!exists) return null;
  
  const type = fs.statSync(full).isDirectory() ? 'dir' : 'file';
  const size = opt.verbose ? await getDirSize(full) : 0;
  
  if (opt.dry) {
    log('[DRY] Would remove ' + type + ': ' + p + (opt.verbose ? ' (' + formatBytes(size) + ')' : ''), 'yellow');
    return size;
  }
  
  fs.rmSync(full, { recursive: true, force: true });
  log('✓ Removed ' + type + ': ' + p + (opt.verbose ? ' (' + formatBytes(size) + ')' : ''), 'green');
  return size;
}

function showHelp() {
  log('\n🧹 rmall - Project cleanup tool\n', 'cyan');
  log('Usage: rmall [options] [path]\n', 'bright');
  log('Options:', 'yellow');
  log('  -h, --help           Show help');
  log('  -d, --dry           Dry run');
  log('  -vv, --verbose      Verbose output');
  log('  -nl, --nolock       Only remove lock files');
  log('  -r, --reinstall    Clean and reinstall\n');
  log('Frameworks:', 'yellow');
  log('  --next, --vite, --svelte, --tauri, --astro, --nuxt\n');
  log('Node modules:', 'yellow');
  log('  -N, --node         Remove ALL node_modules recursively');
  log('  -s, --size        Show size of ALL node_modules\n');
  log('Examples:', 'yellow');
  log('  rmall --dry              # Preview cleanup');
  log('  rmall -N                # Remove all node_modules recursively');
  log('  rmall -N ~/projects     # Remove node_modules in specific path');
  log('  rmall -s                 # Show total node_modules size\n');
}

async function clean() {
  const opt = parseArgs();
  if (opt.help) { showHelp(); return; }
  
  const target = opt.target || process.cwd();
  const cwd = target.startsWith('/') ? target : process.cwd();
  
  if (opt.node) {
    await removeNodeModules(cwd, opt);
    if (opt.reinstall && !opt.dry) {
      execSync('npm install', { stdio: 'inherit', cwd });
    }
    return;
  }
  
  if (opt.size) {
    await calcNodeSizes(cwd);
    return;
  }
  
  const paths = getPaths(opt);
  const toClean = paths.filter(p => fs.existsSync(path.join(cwd, p)));
  
  if (!toClean.length) {
    log('✨ Already clean!', 'green');
    return;
  }
  
  log('\n' + (opt.dry ? '[DRY] ' : '') + '🧹 Cleaning ' + toClean.length + ' items...\n', 'cyan');
  
  const sizes = await Promise.all(toClean.map(p => removePath(p, opt, cwd)));
  const freed = sizes.reduce((a, b) => a + (b || 0), 0);
  
  log('\n✓ ' + (opt.dry ? 'Would free' : 'Freed') + ': ' + formatBytes(freed), 'green');
  
  if (opt.reinstall && !opt.dry) {
    const pm = { bun: 'bun', pnpm: 'pnpm', npm: 'npm', yarn: 'yarn' }[opt.reinstall];
    log('\n📦 Installing with ' + pm + '...', 'cyan');
    execSync(pm + ' install', { stdio: 'inherit', cwd });
  }
  
  log('\n✨ Done!', 'green');
}

clean().catch(e => { log('Error: ' + e.message, 'red'); process.exit(1); });